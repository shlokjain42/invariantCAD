@@ -0,0 +1,35 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright 2026 InvariantCAD contributors
+
+#ifndef INVARIANTCAD_BINTOOLS_V4_PREFLIGHT_H
+#define INVARIANTCAD_BINTOOLS_V4_PREFLIGHT_H
+
+#include <cstddef>
+#include <cstdint>
+
+/// Bounded structural validation result for the exact little-endian,
+/// table-oriented BinTools v4 archive emitted by pinned OCCT 8.0.0.p1.
+struct InvariantCadBinToolsV4PreflightResult {
+    bool ok = false;
+    const char* code = "NOT_RUN";
+    const char* message = "BinTools v4 preflight did not run";
+    int consumedBytes = 0;
+    int workUnits = 0;
+    int maximumDepth = 0;
+    int maximumLocationPower = 0;
+};
+
+/// Parses one complete canonical BinTools v4 archive with a raw byte cursor and
+/// one quota-accounted TShape metrics vector. maxWorkUnits bounds every
+/// attacker-controlled table, array, representation, location-chain, subshape,
+/// expanded topology traversal, and conservative geometry/topology
+/// pair-validation unit. maxTopologyItems rejects an oversized TShape table
+/// before metadata or OCCT allocations. Embedded geometry, location chains,
+/// and the TShape graph share an explicit nesting ceiling; signed location
+/// powers have an independent ceiling. The parser also retains a non-negotiable
+/// implementation safety ceiling of depth 64.
+InvariantCadBinToolsV4PreflightResult invariantcadPreflightBinToolsV4(
+    const uint8_t* bytes, size_t byteCount, int maxTopologyItems,
+    int maxWorkUnits, int maxNestingDepth, int maxLocationPower) noexcept;
+
+#endif
