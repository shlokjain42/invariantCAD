+bool countTopologyWithinBudget(const TopoDS_Shape& root, int maximum,
+                               int& count) {
+    NCollection_IndexedMap<TopoDS_Shape, TopTools_ShapeMapHasher> seen;
+    std::vector<TopoDS_Shape> pending;
+    seen.Add(root);
+    pending.push_back(root);
+    while (!pending.empty()) {
+        const TopoDS_Shape current = pending.back();
+        pending.pop_back();
+        for (TopoDS_Iterator iterator(current, false, false); iterator.More();
+             iterator.Next()) {
+            const TopoDS_Shape& child = iterator.Value();
+            if (seen.Contains(child)) {
+                continue;
+            }
+            if (seen.Extent() >= maximum) {
+                count = seen.Extent();
+                return false;
+            }
+            seen.Add(child);
+            pending.push_back(child);
+        }
+    }
+    count = seen.Extent();
+    return true;
+}
