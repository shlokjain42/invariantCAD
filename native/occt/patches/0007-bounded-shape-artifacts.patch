+        }
+    } catch (const Standard_Failure& error) {
+        consumedByteCount = static_cast<int>(buffer.consumed());
+        return failure("deserialization", "OCCT_EXCEPTION",
+                       error.GetMessageString());
+    } catch (const std::exception& error) {
+        consumedByteCount = static_cast<int>(buffer.consumed());
+        return failure("deserialization", "DESERIALIZATION_FAILED", error.what());
+    } catch (...) {
+        consumedByteCount = static_cast<int>(buffer.consumed());
+        return failure("deserialization", "DESERIALIZATION_FAILED",
+                       "Unknown failure while deserializing binary BREP");
