+        if (buffer.exceeded()) {
+            return failure("serialization", "OUTPUT_LIMIT_EXCEEDED",
+                           "Binary BREP exceeds the configured artifact output limit");
+        }
+        return failure("serialization", "SERIALIZATION_FAILED", error.what());
+    } catch (...) {
+        if (buffer.exceeded()) {
+            return failure("serialization", "OUTPUT_LIMIT_EXCEEDED",
+                           "Binary BREP exceeds the configured artifact output limit");
+        }
+        return failure("serialization", "SERIALIZATION_FAILED",
+                       "Unknown failure while serializing binary BREP");
+    }
+    if (buffer.exceeded()) {
+        return failure("serialization", "OUTPUT_LIMIT_EXCEEDED",
+                       "Binary BREP exceeds the configured artifact output limit");
+    }
+    if (!buffer.output() || buffer.output()->byteCount == 0) {
+        return failure("serialization", "EMPTY_OUTPUT",
+                       "Binary BREP serialization produced no bytes");
+    }
