+InvariantCadArtifactReadReport invariantcadReadArtifactBrep(
+    OcctKernel& kernel, const emscripten::val& input, int maxInputBytes,
+    int maxTopologyItems) {
+    int inputByteCount = 0;
+    int consumedByteCount = 0;
+    int topologyItemCount = 0;
+    auto failure = [&](const char* stage, const char* code,
+                       const std::string& message) {
+        InvariantCadArtifactReadReport report;
+        report.stage = stage;
+        report.code = code;
+        report.message = message;
+        report.inputByteCount = inputByteCount;
+        report.maxInputBytes = maxInputBytes;
+        report.consumedByteCount = consumedByteCount;
+        report.topologyItemCount = topologyItemCount;
+        report.maxTopologyItems = maxTopologyItems;
+        return report;
+    };
+    if (maxInputBytes <= 0) {
+        return failure("validation", "INVALID_INPUT_LIMIT",
+                       "Artifact input limit must be a positive signed 32-bit integer");
+    }
+    if (maxTopologyItems <= 0) {
+        return failure("validation", "INVALID_TOPOLOGY_LIMIT",
+                       "Artifact topology limit must be a positive signed 32-bit integer");
+    }
+
+    try {
+        const emscripten::val uint8Array =
+            emscripten::val::global("Uint8Array");
+        if (!input.instanceof(uint8Array)) {
+            return failure("validation", "INVALID_INPUT_TYPE",
+                           "Artifact input must be a Uint8Array");
+        }
+        const double rawByteCount = input["byteLength"].as<double>();
+        if (!std::isfinite(rawByteCount) || rawByteCount < 0.0 ||
+            std::floor(rawByteCount) != rawByteCount ||
+            rawByteCount > static_cast<double>(std::numeric_limits<int>::max())) {
+            return failure("validation", "INPUT_RANGE",
+                           "Artifact input byte length exceeds the ABI range");
+        }
+        inputByteCount = static_cast<int>(rawByteCount);
+    } catch (const std::exception& error) {
+        return failure("validation", "INVALID_INPUT_TYPE", error.what());
+    } catch (...) {
+        return failure("validation", "INVALID_INPUT_TYPE",
+                       "Unknown failure while inspecting artifact input");
+    }
+    if (inputByteCount == 0) {
+        return failure("validation", "EMPTY_INPUT",
+                       "Artifact input must contain binary BREP bytes");
+    }
+    if (inputByteCount > maxInputBytes) {
+        return failure("validation", "INPUT_LIMIT_EXCEEDED",
+                       "Artifact input exceeds the configured native byte limit");
+    }
