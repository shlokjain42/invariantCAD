+    try {
+        snapshot.resize(static_cast<size_t>(inputByteCount));
+        emscripten::val destination(emscripten::typed_memory_view(
+            snapshot.size(), snapshot.data()));
+        destination.call<void>("set", input);
+    } catch (const std::exception& error) {
+        return failure("copy", "INPUT_COPY_FAILED", error.what());
