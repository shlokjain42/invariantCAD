+class BoundedArtifactOutputBuffer final : public std::streambuf {
+  public:
+    explicit BoundedArtifactOutputBuffer(size_t maximum)
+        : maximum_(maximum), output_(std::make_shared<InvariantCadArtifactWriteState>()) {}
+
+    bool exceeded() const { return exceeded_; }
+    const std::shared_ptr<InvariantCadArtifactWriteState>& output() const { return output_; }
+
+  protected:
+    std::streamsize xsputn(const char* source, std::streamsize count) override {
+        if (count <= 0) {
+            return count < 0 ? 0 : count;
+        }
+        const size_t requested = static_cast<size_t>(count);
+        if (requested > maximum_ - output_->byteCount) {
+            exceeded_ = true;
+            return 0;
+        }
+        append(source, requested);
+        return count;
+    }
+
+    int_type overflow(int_type character) override {
+        if (traits_type::eq_int_type(character, traits_type::eof())) {
+            return traits_type::not_eof(character);
+        }
+        if (output_->byteCount == maximum_) {
+            exceeded_ = true;
+            return traits_type::eof();
+        }
+        const char value = traits_type::to_char_type(character);
+        append(&value, 1);
+        return character;
+    }
+
+  private:
+    void append(const char* source, size_t count) {
+        size_t sourceOffset = 0;
+        while (sourceOffset < count) {
+            if (output_->byteCount == allocatedCapacity_) {
+                const size_t capacity =
+                    std::min(kArtifactChunkBytes, maximum_ - allocatedCapacity_);
+                output_->chunks.emplace_back(capacity);
+                allocatedCapacity_ += capacity;
+            }
+            std::vector<uint8_t>& chunk = output_->chunks.back();
+            const size_t chunkStart = allocatedCapacity_ - chunk.size();
+            const size_t usedInChunk = output_->byteCount - chunkStart;
+            const size_t available = chunk.size() - usedInChunk;
+            const size_t copied = std::min(available, count - sourceOffset);
+            std::memcpy(chunk.data() + usedInChunk, source + sourceOffset, copied);
+            sourceOffset += copied;
+            output_->byteCount += copied;
+        }
+    }
+
+    size_t maximum_ = 0;
+    size_t allocatedCapacity_ = 0;
+    std::shared_ptr<InvariantCadArtifactWriteState> output_;
+    bool exceeded_ = false;
+};
