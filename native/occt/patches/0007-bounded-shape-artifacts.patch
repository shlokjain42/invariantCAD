+emscripten::val InvariantCadArtifactWriteReport::copyBytes() const {
+    if (!hasBytes()) {
+        throw std::logic_error(
+            "InvariantCAD artifact write report has no bytes");
+    }
+    const int count = byteCount();
+    emscripten::val output =
+        emscripten::val::global("Uint8Array").new_(count);
+    size_t remaining = output_->byteCount;
+    size_t offset = 0;
+    for (const std::vector<uint8_t>& chunk : output_->chunks) {
+        const size_t copied = std::min(remaining, chunk.size());
+        if (copied == 0) {
+            break;
+        }
+        output.call<void>(
+            "set", emscripten::val(emscripten::typed_memory_view(
+                       copied, chunk.data())),
+            static_cast<unsigned int>(offset));
+        offset += copied;
+        remaining -= copied;
+    }
+    if (remaining != 0) {
+        throw std::logic_error(
+            "InvariantCAD artifact output chunks are incomplete");
+    }
+    return output;
+}
