@@ -54,0 +66,212 @@ struct TopologyCounts {
+using IndexedShapeMap =
+    NCollection_IndexedMap<TopoDS_Shape, TopTools_ShapeMapHasher>;
+
+const char* topologyKindName(int kind) {
+    switch (kind) {
+    case InvariantCadTopologyKindFace: return "face";
+    case InvariantCadTopologyKindEdge: return "edge";
+    case InvariantCadTopologyKindVertex: return "vertex";
+    default: return "none";
+    }
+}
+
+class HistoryContractError final : public std::runtime_error {
+  public:
+    HistoryContractError(std::string code, std::string message,
+                         int problematicKind = InvariantCadTopologyKindNone,
+                         int problematicIndex = -1,
+                         std::string problemDomain = "none",
+                         int sourceShapeIndex = -1)
+        : std::runtime_error(std::move(message)),
+          code_(std::move(code)),
+          problematicKind_(problematicKind),
+          problematicIndex_(problematicIndex),
+          problemDomain_(std::move(problemDomain)),
+          sourceShapeIndex_(sourceShapeIndex) {}
+
+    const std::string& code() const noexcept { return code_; }
+    int problematicKind() const noexcept { return problematicKind_; }
+    int problematicIndex() const noexcept { return problematicIndex_; }
+    const std::string& problemDomain() const noexcept { return problemDomain_; }
+    int sourceShapeIndex() const noexcept { return sourceShapeIndex_; }
+
+  private:
+    std::string code_;
+    int problematicKind_;
+    int problematicIndex_;
+    std::string problemDomain_;
+    int sourceShapeIndex_;
+};
+
+void indexTopology(const TopoDS_Shape& shape, TopAbs_ShapeEnum type, int kind,
+                   const char* problemDomain, int sourceShapeIndex,
+                   IndexedShapeMap& output) {
+    try {
+        TopExp::MapShapes(shape, type, output);
+    } catch (const Standard_Failure&) {
+        throw HistoryContractError("HISTORY_MAP_OCCT_EXCEPTION",
+                                   "OCCT raised while indexing topology history", kind, -1,
+                                   problemDomain, sourceShapeIndex);
+    } catch (const std::exception&) {
+        throw HistoryContractError("HISTORY_MAP_NATIVE_EXCEPTION",
+                                   "Native code raised while indexing topology history", kind, -1,
+                                   problemDomain, sourceShapeIndex);
+    } catch (...) {
+        throw HistoryContractError("HISTORY_MAP_NATIVE_EXCEPTION",
+                                   "Unknown native failure while indexing topology history", kind,
+                                   -1, problemDomain, sourceShapeIndex);
+    }
+}
+
+void requireEqualHistoryCounts(const IndexedShapeMap& input, const IndexedShapeMap& result,
+                               int kind) {
+    if (input.Extent() != result.Extent()) {
+        throw HistoryContractError(
+            "HISTORY_COUNT_CHANGED",
+            std::string("Draft changed the indexed ") + topologyKindName(kind) + " count", kind);
+    }
+}
+
+void appendDraftTopologyRecords(BRepOffsetAPI_DraftAngle& maker, int kind,
+                                TopAbs_ShapeEnum shapeType, const IndexedShapeMap& input,
+                                const IndexedShapeMap& result,
+                                std::vector<InvariantCadTopologyEvolutionRecord>& records) {
+    std::vector<int> claimedResultIndices(static_cast<size_t>(result.Extent()), -1);
+    for (int oneBasedInputIndex = 1; oneBasedInputIndex <= input.Extent();
+         ++oneBasedInputIndex) {
+        const TopoDS_Shape& source = input.FindKey(oneBasedInputIndex);
+        const int inputIndex = oneBasedInputIndex - 1;
+        TopoDS_Shape successor;
+        try {
+            successor = maker.ModifiedShape(source);
+        } catch (const Standard_Failure&) {
+            throw HistoryContractError(
+                "HISTORY_SUCCESSOR_OCCT_EXCEPTION",
+                "OCCT raised while resolving an indexed topology successor", kind, inputIndex,
+                "source", 0);
+        } catch (const std::exception&) {
+            throw HistoryContractError(
+                "HISTORY_SUCCESSOR_NATIVE_EXCEPTION",
+                "Native code raised while resolving an indexed topology successor", kind,
+                inputIndex, "source", 0);
+        } catch (...) {
+            throw HistoryContractError(
+                "HISTORY_SUCCESSOR_NATIVE_EXCEPTION",
+                "Unknown native failure while resolving an indexed topology successor", kind,
+                inputIndex, "source", 0);
+        }
+
+        if (successor.IsNull()) {
+            throw HistoryContractError(
+                "HISTORY_NULL_SUCCESSOR",
+                "Draft returned a null indexed topology successor at input index " +
+                    std::to_string(inputIndex),
+                kind, inputIndex, "source", 0);
+        }
+        if (successor.ShapeType() != shapeType) {
+            throw HistoryContractError(
+                "HISTORY_SUCCESSOR_TYPE_CHANGED",
+                "Draft changed the topology kind of the successor at input index " +
+                    std::to_string(inputIndex),
+                kind, inputIndex, "source", 0);
+        }
+
+        const int oneBasedResultIndex = result.FindIndex(successor);
+        if (oneBasedResultIndex <= 0) {
+            throw HistoryContractError(
+                "HISTORY_SUCCESSOR_NOT_IN_RESULT",
+                "Draft successor is absent from the final result at input index " +
+                    std::to_string(inputIndex),
+                kind, inputIndex, "source", 0);
+        }
+        const int resultIndex = oneBasedResultIndex - 1;
+        if (claimedResultIndices[static_cast<size_t>(resultIndex)] >= 0) {
+            throw HistoryContractError(
+                "HISTORY_NON_INJECTIVE",
+                "Multiple draft inputs claim result topology index " +
+                    std::to_string(resultIndex),
+                kind, inputIndex, "source", 0);
+        }
+        claimedResultIndices[static_cast<size_t>(resultIndex)] = inputIndex;
+
+        // Map identity is IsSame-based (TShape + Location) so it exactly
+        // matches occt-wasm's TopExp/getSubShapes enumeration. Relation
+        // classification additionally compares the canonical occurrences'
+        // orientations: an orientation-only change is still a modification.
+        const TopoDS_Shape& canonicalResult = result.FindKey(oneBasedResultIndex);
+
+        InvariantCadTopologyEvolutionRecord record;
+        record.sourceShapeIndex = 0;
+        record.sourceKind = kind;
+        record.sourceIndex = inputIndex;
+        record.relation = source.IsEqual(canonicalResult)
+                              ? InvariantCadTopologyRelationPreserved
+                              : InvariantCadTopologyRelationModified;
+        record.resultKind = kind;
+        record.resultIndex = resultIndex;
+        records.push_back(record);
+    }
+
+    for (size_t resultIndex = 0; resultIndex < claimedResultIndices.size(); ++resultIndex) {
+        if (claimedResultIndices[resultIndex] < 0) {
+            throw HistoryContractError(
+                "HISTORY_RESULT_UNCLAIMED",
+                "Draft result topology index has no input successor: " +
+                    std::to_string(resultIndex),
+                kind, static_cast<int>(resultIndex), "result", -1);
+        }
+    }
+}
+
+InvariantCadIndexedTopologyEvolution buildDraftTopologyHistory(
+    BRepOffsetAPI_DraftAngle& maker, const TopoDS_Shape& inputShape,
+    const TopoDS_Shape& resultShape) {
+    IndexedShapeMap inputFaces;
+    IndexedShapeMap inputEdges;
+    IndexedShapeMap inputVertices;
+    IndexedShapeMap resultFaces;
+    IndexedShapeMap resultEdges;
+    IndexedShapeMap resultVertices;
+
+    indexTopology(inputShape, TopAbs_FACE, InvariantCadTopologyKindFace, "source", 0,
+                  inputFaces);
+    indexTopology(inputShape, TopAbs_EDGE, InvariantCadTopologyKindEdge, "source", 0,
+                  inputEdges);
+    indexTopology(inputShape, TopAbs_VERTEX, InvariantCadTopologyKindVertex, "source", 0,
+                  inputVertices);
+    indexTopology(resultShape, TopAbs_FACE, InvariantCadTopologyKindFace, "result", -1,
+                  resultFaces);
+    indexTopology(resultShape, TopAbs_EDGE, InvariantCadTopologyKindEdge, "result", -1,
+                  resultEdges);
+    indexTopology(resultShape, TopAbs_VERTEX, InvariantCadTopologyKindVertex, "result", -1,
+                  resultVertices);
+
+    requireEqualHistoryCounts(inputFaces, resultFaces, InvariantCadTopologyKindFace);
+    requireEqualHistoryCounts(inputEdges, resultEdges, InvariantCadTopologyKindEdge);
+    requireEqualHistoryCounts(inputVertices, resultVertices, InvariantCadTopologyKindVertex);
+
+    InvariantCadIndexedTopologyEvolution history;
+    history.version = kTopologyHistoryVersion;
+    history.inputCounts.push_back(
+        {inputFaces.Extent(), inputEdges.Extent(), inputVertices.Extent()});
+    history.resultCounts =
+        {resultFaces.Extent(), resultEdges.Extent(), resultVertices.Extent()};
+    const uint64_t recordCount = static_cast<uint64_t>(inputFaces.Extent()) +
+                                 static_cast<uint64_t>(inputEdges.Extent()) +
+                                 static_cast<uint64_t>(inputVertices.Extent());
+    if (recordCount > static_cast<uint64_t>(std::numeric_limits<int>::max())) {
+        throw HistoryContractError("HISTORY_RECORD_COUNT_OVERFLOW",
+                                   "Indexed topology history exceeds the ABI record range");
+    }
+    history.records.reserve(static_cast<size_t>(recordCount));
+
+    appendDraftTopologyRecords(maker, InvariantCadTopologyKindFace, TopAbs_FACE, inputFaces,
+                               resultFaces, history.records);
+    appendDraftTopologyRecords(maker, InvariantCadTopologyKindEdge, TopAbs_EDGE, inputEdges,
+                               resultEdges, history.records);
+    appendDraftTopologyRecords(maker, InvariantCadTopologyKindVertex, TopAbs_VERTEX,
+                               inputVertices, resultVertices, history.records);
+    history.complete = true;
+    return history;
+}
