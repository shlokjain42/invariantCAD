+
+bool InvariantCadDraftReport::topologyHistoryComplete() const {
+    return transfer_ && transfer_->topologyHistory.complete;
+}
+
+int InvariantCadDraftReport::topologyInputShapeCount() const {
+    if (!topologyHistoryComplete()) {
+        return 0;
+    }
+    if (transfer_->topologyHistory.inputCounts.size() >
+        static_cast<size_t>(std::numeric_limits<int>::max())) {
+        throw std::overflow_error("InvariantCAD topology input count exceeds the ABI range");
+    }
+    return static_cast<int>(transfer_->topologyHistory.inputCounts.size());
+}
+
+InvariantCadTopologyCounts InvariantCadDraftReport::topologyInputCounts(
+    int sourceShapeIndex) const {
+    if (!topologyHistoryComplete()) {
+        throw std::logic_error("InvariantCAD draft topology history is unavailable");
+    }
+    if (sourceShapeIndex < 0 ||
+        static_cast<size_t>(sourceShapeIndex) >= transfer_->topologyHistory.inputCounts.size()) {
+        throw std::out_of_range("InvariantCAD topology input shape index is out of range");
+    }
+    return transfer_->topologyHistory.inputCounts[static_cast<size_t>(sourceShapeIndex)];
+}
+
+InvariantCadTopologyCounts InvariantCadDraftReport::topologyResultCounts() const {
+    if (!topologyHistoryComplete()) {
+        throw std::logic_error("InvariantCAD draft topology history is unavailable");
+    }
+    return transfer_->topologyHistory.resultCounts;
+}
+
+int InvariantCadDraftReport::topologyRecordCount() const {
+    if (!topologyHistoryComplete()) {
+        return 0;
+    }
+    if (transfer_->topologyHistory.records.size() >
+        static_cast<size_t>(std::numeric_limits<int>::max())) {
+        throw std::overflow_error("InvariantCAD topology record count exceeds the ABI range");
+    }
+    return static_cast<int>(transfer_->topologyHistory.records.size());
+}
+
+InvariantCadTopologyEvolutionRecord InvariantCadDraftReport::topologyRecord(
+    int recordIndex) const {
+    if (!topologyHistoryComplete()) {
+        throw std::logic_error("InvariantCAD draft topology history is unavailable");
+    }
+    if (recordIndex < 0 ||
+        static_cast<size_t>(recordIndex) >= transfer_->topologyHistory.records.size()) {
+        throw std::out_of_range("InvariantCAD topology record index is out of range");
+    }
+    return transfer_->topologyHistory.records[static_cast<size_t>(recordIndex)];
+}
