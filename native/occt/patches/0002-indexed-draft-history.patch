+/// Evaluation-scoped topology kinds used by the indexed evolution ABI.
+/// These numeric values are stable across facade ABI 0.2.x.
+enum InvariantCadTopologyKind : int {
+    InvariantCadTopologyKindNone = -1,
+    InvariantCadTopologyKindFace = 0,
+    InvariantCadTopologyKindEdge = 1,
+    InvariantCadTopologyKindVertex = 2,
+};
+
+/// Source-to-result relations used by the generic indexed evolution envelope.
+/// Atomic draft emits only Preserved and Modified records. Generated, Deleted,
+/// and Created are reserved for later topology-changing facade operations.
+enum InvariantCadTopologyRelation : int {
+    InvariantCadTopologyRelationPreserved = 0,
+    InvariantCadTopologyRelationModified = 1,
+    InvariantCadTopologyRelationGenerated = 2,
+    InvariantCadTopologyRelationDeleted = 3,
+    InvariantCadTopologyRelationCreated = 4,
+};
+
+/// Number of unique located subshapes indexed by TopExp::MapShapes for each
+/// topology kind. Orientation occurrences are deliberately not separate IDs;
+/// however, the canonical input/result occurrences' orientations participate
+/// in Preserved-versus-Modified classification.
+struct InvariantCadTopologyCounts {
+    int faces = 0;
+    int edges = 0;
+    int vertices = 0;
+};
+
+/// One generic indexed evolution link. All indices are zero-based. A deleted
+/// record uses -1 for resultKind/resultIndex; a source-less created record uses
+/// -1 for all three source fields. sourceShapeIndex distinguishes operands.
+/// Records are canonicalized by source operand, source kind, source index,
+/// relation, result kind, and result index. Atomic draft's stricter one-to-one
+/// subset is emitted as faces, then edges, then vertices, each by input index.
+struct InvariantCadTopologyEvolutionRecord {
+    int sourceShapeIndex = -1;
+    int sourceKind = InvariantCadTopologyKindNone;
+    int sourceIndex = -1;
+    int relation = InvariantCadTopologyRelationPreserved;
+    int resultKind = InvariantCadTopologyKindNone;
+    int resultIndex = -1;
+};
+
