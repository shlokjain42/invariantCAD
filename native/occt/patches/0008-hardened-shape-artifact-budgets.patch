diff --git a/facade/include/invariantcad_allocation_budget.h b/facade/include/invariantcad_allocation_budget.h
new file mode 100644
index 0000000..c49d489
--- /dev/null
+++ b/facade/include/invariantcad_allocation_budget.h
@@ -0,0 +1,35 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright 2026 InvariantCAD contributors
+//
+// InvariantCAD-owned extension code.
+
+#pragma once
+
+#include <cstddef>
+
+struct InvariantCadNativeAllocationSnapshot {
+    std::size_t maximumRequestedBytes = 0;
+    std::size_t requestedBytes = 0;
+    int allocationCalls = 0;
+    bool exceeded = false;
+};
+
+// Empty, allocation-free exception used only by reviewed throwing allocator
+// entry points. Direct C allocator denials are deliberately fail-stop.
+struct InvariantCadNativeAllocationLimitExceeded final {};
+
+class InvariantCadNativeAllocationScope final {
+  public:
+    explicit InvariantCadNativeAllocationScope(std::size_t maximumRequestedBytes) noexcept;
+    ~InvariantCadNativeAllocationScope();
+
+    InvariantCadNativeAllocationScope(const InvariantCadNativeAllocationScope&) = delete;
+    InvariantCadNativeAllocationScope& operator=(
+        const InvariantCadNativeAllocationScope&) = delete;
+
+    bool exceeded() const noexcept;
+    InvariantCadNativeAllocationSnapshot stop() noexcept;
+
+  private:
+    bool active_ = false;
+};
diff --git a/facade/src/invariantcad_allocation_budget.cpp b/facade/src/invariantcad_allocation_budget.cpp
