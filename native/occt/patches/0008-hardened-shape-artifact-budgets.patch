diff --git a/facade/src/invariantcad_allocation_budget.cpp b/facade/src/invariantcad_allocation_budget.cpp
new file mode 100644
index 0000000..b4b6158
--- /dev/null
+++ b/facade/src/invariantcad_allocation_budget.cpp
@@ -0,0 +1,223 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright 2026 InvariantCAD contributors
+//
+// InvariantCAD-owned extension code.
+
+#include "invariantcad_allocation_budget.h"
+
+#include <climits>
+#include <cstdint>
+#include <cstdlib>
+#include <limits>
+#include <new>
+
+namespace {
+
+struct NativeAllocationBudgetState {
+    std::size_t maximumRequestedBytes = 0;
+    std::size_t requestedBytes = 0;
+    int allocationCalls = 0;
+    bool active = false;
+    bool exceeded = false;
+};
+
+thread_local NativeAllocationBudgetState THE_BUDGET;
+thread_local unsigned int THE_ALLOCATOR_BYPASS_DEPTH = 0;
+
+class AllocatorBypassScope final {
+  public:
+    AllocatorBypassScope() noexcept { ++THE_ALLOCATOR_BYPASS_DEPTH; }
+    ~AllocatorBypassScope() { --THE_ALLOCATOR_BYPASS_DEPTH; }
+
+    AllocatorBypassScope(const AllocatorBypassScope&) = delete;
+    AllocatorBypassScope& operator=(const AllocatorBypassScope&) = delete;
+};
+
+bool allocatorBypassed() noexcept { return THE_ALLOCATOR_BYPASS_DEPTH != 0; }
+
+bool chargeRequest(std::size_t requestedBytes) noexcept {
+    if (!THE_BUDGET.active || allocatorBypassed()) {
+        return true;
+    }
+    if (THE_BUDGET.allocationCalls == INT_MAX) {
+        THE_BUDGET.exceeded = true;
+        return false;
+    }
+    ++THE_BUDGET.allocationCalls;
+    if (requestedBytes >
+        THE_BUDGET.maximumRequestedBytes - THE_BUDGET.requestedBytes) {
+        THE_BUDGET.exceeded = true;
+        return false;
+    }
+    THE_BUDGET.requestedBytes += requestedBytes;
+    return true;
+}
+
+[[noreturn]] void throwAllocationLimit() {
+    // C++ exception construction and stack unwinding may allocate. Once the
+    // limit is latched, switch to emergency unmetered cleanup until the owning
+    // artifact scope snapshots and clears the state.
+    THE_ALLOCATOR_BYPASS_DEPTH = 1;
+    throw InvariantCadNativeAllocationLimitExceeded{};
+}
+
+[[noreturn]] void failStopAllocationLimit() noexcept { std::abort(); }
+
+template <typename Function>
+void* callRealAllocator(Function function) noexcept {
+    AllocatorBypassScope bypass;
+    return function();
+}
+
+} // namespace
+
+InvariantCadNativeAllocationScope::InvariantCadNativeAllocationScope(
+    std::size_t maximumRequestedBytes) noexcept {
+    if (THE_BUDGET.active || THE_ALLOCATOR_BYPASS_DEPTH != 0 ||
+        maximumRequestedBytes == 0) {
+        std::abort();
+    }
+    THE_BUDGET = NativeAllocationBudgetState{
+        maximumRequestedBytes, 0, 0, true, false};
+    active_ = true;
+}
+
+InvariantCadNativeAllocationScope::~InvariantCadNativeAllocationScope() {
+    if (active_) {
+        THE_BUDGET = NativeAllocationBudgetState{};
+        THE_ALLOCATOR_BYPASS_DEPTH = 0;
+    }
+}
+
+bool InvariantCadNativeAllocationScope::exceeded() const noexcept {
+    return active_ && THE_BUDGET.exceeded;
+}
+
+InvariantCadNativeAllocationSnapshot
+InvariantCadNativeAllocationScope::stop() noexcept {
+    if (!active_) {
+        std::abort();
+    }
+    const InvariantCadNativeAllocationSnapshot snapshot{
+        THE_BUDGET.maximumRequestedBytes,
+        THE_BUDGET.requestedBytes,
+        THE_BUDGET.allocationCalls,
+        THE_BUDGET.exceeded,
+    };
+    THE_BUDGET = NativeAllocationBudgetState{};
+    THE_ALLOCATOR_BYPASS_DEPTH = 0;
+    active_ = false;
+    return snapshot;
+}
+
+extern "C" void* __real__ZN8Standard8AllocateEm(std::size_t);
+extern "C" void* __real__ZN8Standard15AllocateOptimalEm(std::size_t);
+extern "C" void* __real__ZN8Standard10ReallocateEPvm(void*, std::size_t);
+extern "C" void* __real__ZN8Standard15AllocateAlignedEmm(
+    std::size_t, std::size_t);
+
+extern "C" void* __wrap__ZN8Standard8AllocateEm(std::size_t size) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__ZN8Standard8AllocateEm(size);
+}
+
+extern "C" void* __wrap__ZN8Standard15AllocateOptimalEm(std::size_t size) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__ZN8Standard15AllocateOptimalEm(size);
+}
+
+extern "C" void* __wrap__ZN8Standard10ReallocateEPvm(
+    void* pointer, std::size_t size) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__ZN8Standard10ReallocateEPvm(pointer, size);
+}
+
+extern "C" void* __wrap__ZN8Standard15AllocateAlignedEmm(
+    std::size_t size, std::size_t alignment) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__ZN8Standard15AllocateAlignedEmm(size, alignment);
+}
+
+extern "C" void* __real__Znwm(std::size_t);
+extern "C" void* __real__Znam(std::size_t);
+
+extern "C" void* __wrap__Znwm(std::size_t size) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__Znwm(size);
+}
+
+extern "C" void* __wrap__Znam(std::size_t size) {
+    if (!chargeRequest(size)) throwAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real__Znam(size);
+}
+
+extern "C" void* __real_malloc(std::size_t);
+extern "C" void* __real_calloc(std::size_t, std::size_t);
+extern "C" void* __real_realloc(void*, std::size_t);
+extern "C" int __real_posix_memalign(void**, std::size_t, std::size_t);
+extern "C" void* __real_aligned_alloc(std::size_t, std::size_t);
+extern "C" void* __real_memalign(std::size_t, std::size_t);
+
+extern "C" void* __wrap_malloc(std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) return __real_malloc(size);
+    if (!chargeRequest(size)) failStopAllocationLimit();
+    return callRealAllocator([&]() { return __real_malloc(size); });
+}
+
+extern "C" void* __wrap_calloc(
+    std::size_t count, std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) {
+        return __real_calloc(count, size);
+    }
+    if (count != 0 && size > std::numeric_limits<std::size_t>::max() / count) {
+        THE_BUDGET.exceeded = true;
+        failStopAllocationLimit();
+    }
+    const std::size_t requestedBytes = count * size;
+    if (!chargeRequest(requestedBytes)) failStopAllocationLimit();
+    return callRealAllocator([&]() { return __real_calloc(count, size); });
+}
+
+extern "C" void* __wrap_realloc(
+    void* pointer, std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) {
+        return __real_realloc(pointer, size);
+    }
+    if (!chargeRequest(size)) failStopAllocationLimit();
+    return callRealAllocator([&]() { return __real_realloc(pointer, size); });
+}
+
+extern "C" int __wrap_posix_memalign(
+    void** pointer, std::size_t alignment, std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) {
+        return __real_posix_memalign(pointer, alignment, size);
+    }
+    if (!chargeRequest(size)) failStopAllocationLimit();
+    AllocatorBypassScope bypass;
+    return __real_posix_memalign(pointer, alignment, size);
+}
+
+extern "C" void* __wrap_aligned_alloc(
+    std::size_t alignment, std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) {
+        return __real_aligned_alloc(alignment, size);
+    }
+    if (!chargeRequest(size)) failStopAllocationLimit();
+    return callRealAllocator(
+        [&]() { return __real_aligned_alloc(alignment, size); });
+}
+
+extern "C" void* __wrap_memalign(
+    std::size_t alignment, std::size_t size) noexcept {
+    if (allocatorBypassed() || !THE_BUDGET.active) {
+        return __real_memalign(alignment, size);
+    }
+    if (!chargeRequest(size)) failStopAllocationLimit();
+    return callRealAllocator([&]() { return __real_memalign(alignment, size); });
+}
