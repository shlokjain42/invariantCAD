+        report.direction = direction;
+        report.amount = amount;
+        report.tolerance = tolerance;
+        report.requestedOpeningFaceCount = requestedOpeningFaceCount;
+        report.buildCount = buildCount;
+        report.occtStatus = occtStatus;
+        report.failedOpeningFaceIndex = failedOpeningFaceIndex;
+        report.selectedOpeningFaceIndices_ = selectedOpeningFaceIndices;
