+                                 InvariantCadTopologyKindVertex}) {
+        const IndexedShapeMap& sourceMap = mapForKind(copiedInput, sourceKind);
+        const IndexedShapeMap& resultMap = mapForKind(result, sourceKind);
+        for (int oneBasedSourceIndex = 1;
+             oneBasedSourceIndex <= sourceMap.Extent(); ++oneBasedSourceIndex) {
+            const TopoDS_Shape& source = sourceMap.FindKey(oneBasedSourceIndex);
+            if (resultMap.FindIndex(source) > 0 ||
+                !nativeHistory.Modified(source).IsEmpty() ||
+                nativeHistory.IsRemoved(source)) {
+                continue;
+            }
+            // BRepOffset_MakeOffset::IsDeleted returns false when a source has
+            // Generated successors, even though the source identity is absent
+            // from the final shape. BRepTools_History explicitly permits a
+            // removed source to retain Generated links. Final membership makes
+            // this terminal identity relation exact rather than heuristic.
+            nativeHistory.Remove(source);
+        }
+    }
