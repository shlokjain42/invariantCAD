+
+int InvariantCadSolidOffsetReport::selectedOpeningFaceIndex(
+    int selectedIndex) const {
+    if (selectedIndex < 0 || static_cast<size_t>(selectedIndex) >=
+                                 selectedOpeningFaceIndices_.size()) {
