+        if (!copier->IsDone()) {
+            return failure("copy", "OPERAND_COPY_FAILED",
+                           "OCCT did not complete the solid-offset operand copy");
+        }
+        TopoDS_Shape copiedShape = copier->Shape();
+        if (copiedShape.IsNull() || copiedShape.IsSame(inputSolid)) {
+            return failure("copy", "OPERAND_COPY_NOT_ISOLATED",
+                           "OCCT did not isolate the solid-offset operand");
+        }
+        if (inputSignedVolume < 0.0) {
+            copiedShape.Reverse();
+        }
+        operandCopies.push_back({std::move(copier), copiedShape});
+    } catch (const Standard_Failure& error) {
+        return failure("copy", "OPERAND_COPY_OCCT_EXCEPTION",
+                       error.GetMessageString());
+    } catch (const std::exception& error) {
+        return failure("copy", "OPERAND_COPY_NATIVE_EXCEPTION", error.what());
+    } catch (...) {
+        return failure("copy", "OPERAND_COPY_NATIVE_EXCEPTION",
+                       "Unknown failure while copying the solid-offset operand");
+    }
+
+    NCollection_List<TopoDS_Shape> copiedOpeningFaces;
+    try {
+        const IndexedOperandTopology copiedInput =
+            indexOperandTopology(operandCopies.front().shape, 0, "source");
+        for (size_t selectedIndex = 0;
+             selectedIndex < selectedOpeningFaceIndices.size(); ++selectedIndex) {
+            failedOpeningFaceIndex = static_cast<int>(selectedIndex);
+            const int faceIndex = selectedOpeningFaceIndices[selectedIndex];
+            const TopoDS_Shape mappedFace = copiedTopologySource(
+                operandCopies.front(), inputFaces.FindKey(faceIndex + 1), 0,
+                InvariantCadTopologyKindFace, faceIndex);
+            const int oneBasedCopiedFaceIndex =
+                copiedInput.faces.FindIndex(mappedFace);
+            if (oneBasedCopiedFaceIndex <= 0) {
+                return failure("copy", "OPENING_COPY_NOT_IN_OPERAND",
+                               "Copied opening face is absent from the operand copy");
+            }
+            copiedOpeningFaces.Append(
+                copiedInput.faces.FindKey(oneBasedCopiedFaceIndex));
+        }
+        failedOpeningFaceIndex = -1;
+    } catch (const HistoryContractError& error) {
+        return failure("copy", error.code().c_str(), error.what());
+    } catch (const Standard_Failure& error) {
+        return failure("copy", "OPENING_COPY_OCCT_EXCEPTION",
+                       error.GetMessageString());
+    } catch (const std::exception& error) {
+        return failure("copy", "OPENING_COPY_NATIVE_EXCEPTION", error.what());
+    } catch (...) {
+        return failure("copy", "OPENING_COPY_NATIVE_EXCEPTION",
+                       "Unknown failure while mapping copied opening faces");
+    }
+
+    auto execute = [&](auto& maker, auto&& perform)
+        -> InvariantCadSolidOffsetReport {
+        try {
+            ++buildCount;
+            perform();
+            occtStatus = static_cast<int>(maker.MakeOffset().Error());
+        } catch (const Standard_Failure& error) {
+            return failure("build", "BUILD_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("build", "BUILD_NATIVE_EXCEPTION", error.what());
+        } catch (...) {
+            return failure("build", "BUILD_NATIVE_EXCEPTION",
+                           "Unknown failure while building the solid offset");
+        }
+        if (!maker.IsDone()) {
+            return failure("build", "BUILD_FAILED",
+                           "OCCT did not complete the solid offset");
+        }
+        if (occtStatus != 0) {
+            return failure("build", "OFFSET_STATUS_FAILED",
+                           "OCCT reported a solid-offset construction error");
+        }
+
+        TopoDS_Shape makerResult;
+        try {
+            makerResult = maker.Shape();
+        } catch (const Standard_Failure& error) {
+            return failure("result-validation", "RESULT_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("result-validation", "RESULT_NATIVE_EXCEPTION",
+                           error.what());
+        } catch (...) {
+            return failure("result-validation", "RESULT_NATIVE_EXCEPTION",
+                           "Unknown failure while retrieving the solid-offset result");
+        }
+        if (makerResult.IsNull()) {
+            return failure("result-validation", "NULL_RESULT",
+                           "OCCT completed without a solid-offset result");
+        }
+        TopoDS_Shape result;
+        if (!extractPureSingleSolid(makerResult, result)) {
+            return failure("result-validation", "RESULT_NOT_TOP_LEVEL_SOLID",
+                           "Solid-offset result is not a pure single solid");
+        }
+
+        double resultVolume = 0.0;
+        try {
+            resultVolume = signedVolume(result);
+            if (std::isfinite(resultVolume) && resultVolume < -volumeTolerance) {
+                result.Reverse();
+                resultVolume = signedVolume(result);
+            }
+            if (!BRepCheck_Analyzer(result).IsValid()) {
+                return failure("result-validation", "INVALID_RESULT_SOLID",
+                               "OCCT produced a topologically invalid solid");
+            }
+            if (topologyCounts(result).solids != 1) {
+                return failure("result-validation", "RESULT_NOT_SINGLE_SOLID",
+                               "Solid-offset result must contain exactly one solid");
+            }
+            if (!std::isfinite(resultVolume) ||
+                !(resultVolume > volumeTolerance)) {
+                return failure("result-validation", "RESULT_NOT_POSITIVE_VOLUME",
+                               "Solid-offset result must have positive finite volume");
+            }
+            if (operation == InvariantCadSolidOffsetOperationShell &&
+                direction == InvariantCadSolidOffsetDirectionInward &&
+                !(resultVolume < inputVolume - volumeTolerance)) {
+                return failure("result-validation", "SHELL_NOT_HOLLOWED",
+                               "Inward shell did not reduce the solid volume");
+            }
+            if (operation == InvariantCadSolidOffsetOperationOffset &&
+                direction == InvariantCadSolidOffsetDirectionOutward &&
+                !(resultVolume > inputVolume + volumeTolerance)) {
+                return failure("result-validation", "OUTWARD_OFFSET_NOT_LARGER",
+                               "Outward offset did not increase the solid volume");
+            }
+            if (operation == InvariantCadSolidOffsetOperationOffset &&
+                direction == InvariantCadSolidOffsetDirectionInward &&
+                !(resultVolume < inputVolume - volumeTolerance)) {
+                return failure("result-validation", "INWARD_OFFSET_NOT_SMALLER",
+                               "Inward offset did not decrease the solid volume");
+            }
+        } catch (const Standard_Failure& error) {
+            return failure("result-validation", "RESULT_VALIDATION_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("result-validation", "RESULT_VALIDATION_NATIVE_EXCEPTION",
+                           error.what());
+        } catch (...) {
+            return failure("result-validation", "RESULT_VALIDATION_NATIVE_EXCEPTION",
+                           "Unknown failure while validating the solid-offset result");
+        }
+
+        InvariantCadIndexedTopologyEvolution topologyHistory;
+        try {
+            NCollection_List<TopoDS_Shape> arguments;
+            arguments.Append(operandCopies.front().shape);
+            BRepTools_History nativeHistory(arguments, maker);
+            reconcileGeneratedOnlyReplacements(
+                nativeHistory, operandCopies.front().shape, result);
+            topologyHistory = buildCompleteTopologyHistory(
+                nativeHistory, std::vector<TopoDS_Shape>{inputShape},
+                operandCopies, result, maxHistoryRecords);
+        } catch (const HistoryContractError& error) {
+            InvariantCadSolidOffsetReport report =
+                failure("history", error.code().c_str(), error.what());
+            report.historyProblemDomain = error.problemDomain();
+            report.historyProblemSourceShapeIndex = error.sourceShapeIndex();
+            report.historyProblemKind = error.problematicKind();
+            report.historyProblemIndex = error.problematicIndex();
+            return report;
+        } catch (const Standard_Failure& error) {
+            return failure("history", "HISTORY_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("history", "HISTORY_NATIVE_EXCEPTION", error.what());
+        } catch (...) {
+            return failure("history", "HISTORY_NATIVE_EXCEPTION",
+                           "Unknown failure while proving solid-offset history");
+        }
+
+        InvariantCadSolidOffsetReport report;
+        report.ok = true;
+        report.stage = "complete";
+        report.code = "OK";
+        report.message =
+            "Solid-offset result and exact indexed history are ready";
+        report.operation = operation;
+        report.direction = direction;
+        report.amount = amount;
+        report.tolerance = tolerance;
+        report.requestedOpeningFaceCount = requestedOpeningFaceCount;
+        report.buildCount = buildCount;
+        report.occtStatus = occtStatus;
+        report.failedOpeningFaceIndex = -1;
+        report.selectedOpeningFaceIndices_ = selectedOpeningFaceIndices;
+        report.transfer_ =
+            std::make_shared<InvariantCadSolidOffsetTransferState>();
+        report.transfer_->result = result;
+        report.transfer_->kernelInstanceToken = kernel.invariantcadInstanceToken_;
+        report.transfer_->topologyHistory = std::move(topologyHistory);
+        return report;
+    };
+
+    const double signedAmount =
+        direction == InvariantCadSolidOffsetDirectionInward ? -amount : amount;
+    try {
+        if (operation == InvariantCadSolidOffsetOperationShell) {
+            BRepOffsetAPI_MakeThickSolid maker;
+            return execute(maker, [&]() {
+                maker.MakeThickSolidByJoin(
+                    operandCopies.front().shape, copiedOpeningFaces,
+                    signedAmount, tolerance, BRepOffset_Skin, false, false,
+                    GeomAbs_Arc, false);
+            });
+        }
+        BRepOffsetAPI_MakeOffsetShape maker;
+        return execute(maker, [&]() {
+            maker.PerformByJoin(operandCopies.front().shape, signedAmount,
+                                tolerance, BRepOffset_Skin, false, false,
+                                GeomAbs_Arc, false);
+        });
+    } catch (const Standard_Failure& error) {
+        return failure("construction", "MAKER_OCCT_EXCEPTION",
+                       error.GetMessageString());
+    } catch (const std::exception& error) {
+        return failure("construction", "MAKER_NATIVE_EXCEPTION", error.what());
+    } catch (...) {
+        return failure("construction", "MAKER_NATIVE_EXCEPTION",
+                       "Unknown failure while constructing the solid-offset maker");
+    }
+}
+
