+        return failure("validation", "TOLERANCE_NOT_LESS_THAN_AMOUNT",
+                       "Solid-offset tolerance must be less than its amount");
+    }
+    if (maxHistoryRecords < 0) {
+        return failure("validation", "INVALID_HISTORY_RECORD_LIMIT",
+                       "Solid-offset history record limit must be non-negative");
+    }
