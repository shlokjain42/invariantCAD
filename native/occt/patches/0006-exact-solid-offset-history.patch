+    const IndexedOperandTopology copiedInput =
+        indexOperandTopology(copiedInputShape, 0, "source");
+    const IndexedOperandTopology result =
+        indexOperandTopology(resultShape, -1, "result");
+    for (const int sourceKind : {InvariantCadTopologyKindFace,
