+class OcctKernel;
+struct InvariantCadDraftTransferState;
+
+/// Returns a process-monotonic token for one OcctKernel instance. This is
+/// inline so upstream's WASI build, which compiles only kernel.cpp from the
+/// handwritten source directory, retains a self-contained OcctKernel ctor.
+inline uint64_t invariantcadNextKernelInstanceToken() {
+    static std::atomic<uint64_t> nextToken{1};
+    uint64_t token = nextToken.load(std::memory_order_relaxed);
+    for (;;) {
+        if (token == std::numeric_limits<uint64_t>::max()) {
+            throw std::overflow_error("InvariantCAD kernel instance token space exhausted");
+        }
+        if (nextToken.compare_exchange_weak(token, token + 1, std::memory_order_relaxed,
+                                            std::memory_order_relaxed)) {
+            return token;
+        }
+    }
+}
+
+/// Owned result of InvariantCAD's atomic multi-face draft facade.
+///
+/// The result shape deliberately remains outside OcctKernel's arena until
+/// takeResultId() is called. Destroying an untaken report therefore releases
+/// the shape without leaking an arena entry.
+struct InvariantCadDraftReport {
+    bool ok = false;
+    std::string stage = "validation";
+    std::string code = "INTERNAL_ERROR";
+    std::string message;
+    int failedSeedIndex = -1;
+    int occtStatus = -1;
+    int requestedSeedCount = 0;
+    int addCount = 0;
+    int skippedSeedCount = 0;
+    int buildCount = 0;
+    std::string problematicShapeType = "none";
+    int problematicShapeIndex = -1;
+
+    InvariantCadDraftReport() = default;
+    InvariantCadDraftReport(const InvariantCadDraftReport&) = default;
+    InvariantCadDraftReport& operator=(const InvariantCadDraftReport&) = default;
+
+    bool getOk() const { return ok; }
+    std::string getStage() const { return stage; }
+    std::string getCode() const { return code; }
+    std::string getMessage() const { return message; }
+    int getFailedSeedIndex() const { return failedSeedIndex; }
+    int getOcctStatus() const { return occtStatus; }
+    int getRequestedSeedCount() const { return requestedSeedCount; }
+    int getAddCount() const { return addCount; }
+    int getSkippedSeedCount() const { return skippedSeedCount; }
+    int getBuildCount() const { return buildCount; }
+    std::string getProblematicShapeType() const { return problematicShapeType; }
+    int getProblematicShapeIndex() const { return problematicShapeIndex; }
+
+    /// Transfers a successful result into kernel's arena exactly once.
+    /// Call transferCode(kernel) first; it is the stable rejection contract.
+    /// The preflight plus take sequence assumes occt-wasm's current synchronous,
+    /// non-pthreaded Embind execution model.
+    uint32_t takeResultId(OcctKernel& kernel);
+    bool hasResult() const;
+    std::string transferCode(const OcctKernel& kernel) const;
+
+  private:
+    std::shared_ptr<InvariantCadDraftTransferState> transfer_;
+
+    friend InvariantCadDraftReport invariantcadDraftFacesAtomic(
+        OcctKernel& kernel, uint32_t shapeId, std::vector<uint32_t> faceIds, double angleRad,
+        double pullX, double pullY, double pullZ, double neutralOriginX, double neutralOriginY,
+        double neutralOriginZ, double neutralNormalX, double neutralNormalY,
+        double neutralNormalZ);
+};
+
+/// Versioned InvariantCAD extension probe, independent of occt-wasm's API.
+std::string invariantcadFacadeVersion();
+
+/// Applies all requested draft faces to one BRepOffsetAPI_DraftAngle maker,
+/// verifies every Add(), and calls Build() once after all additions succeed.
+/// Raw arena IDs are adapter-trusted capability handles. This facade validates
+/// type and membership inside the supplied kernel, but IDs do not authenticate
+/// their originating JavaScript wrapper or another kernel instance.
+InvariantCadDraftReport invariantcadDraftFacesAtomic(
+    OcctKernel& kernel, uint32_t shapeId, std::vector<uint32_t> faceIds, double angleRad,
+    double pullX, double pullY, double pullZ, double neutralOriginX, double neutralOriginY,
+    double neutralOriginZ, double neutralNormalX, double neutralNormalY, double neutralNormalZ);
@@ -127,0 +218,4 @@ class OcctKernel {
+    OcctKernel(const OcctKernel&) = delete;
+    OcctKernel& operator=(const OcctKernel&) = delete;
+    OcctKernel(OcctKernel&&) = delete;
+    OcctKernel& operator=(OcctKernel&&) = delete;
@@ -434,0 +529,6 @@ class OcctKernel {
