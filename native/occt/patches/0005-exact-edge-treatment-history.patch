+
+InvariantCadTopologyCounts InvariantCadEdgeTreatmentReport::topologyInputCounts(
+    int sourceShapeIndex) const {
+    if (!topologyHistoryComplete()) {
+        throw std::logic_error(
+            "InvariantCAD edge-treatment topology history is unavailable");
+    }
+    if (sourceShapeIndex < 0 ||
+        static_cast<size_t>(sourceShapeIndex) >=
+            transfer_->topologyHistory.inputCounts.size()) {
+        throw std::out_of_range(
+            "InvariantCAD edge-treatment topology input shape index is out of range");
+    }
+    return transfer_->topologyHistory.inputCounts[
+        static_cast<size_t>(sourceShapeIndex)];
