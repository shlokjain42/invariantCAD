+            return failure("seed-add", "SEED_ADD_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("seed-add", "SEED_ADD_NATIVE_EXCEPTION", error.what());
+        } catch (...) {
+            return failure("seed-add", "SEED_ADD_NATIVE_EXCEPTION",
+                           "Unknown failure while adding edge-treatment seeds");
+        }
+        if (contourCount <= 0 || addCount <= 0) {
+            return failure("seed-add", "NO_CONTOURS",
+                           "Edge-treatment seeds did not define any contour");
+        }
+
+        try {
+            ++buildCount;
+            maker.Build();
+        } catch (const Standard_Failure& error) {
+            return failure("build", "BUILD_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("build", "BUILD_NATIVE_EXCEPTION", error.what());
+        } catch (...) {
+            return failure("build", "BUILD_NATIVE_EXCEPTION",
+                           "Unknown failure while building the edge treatment");
+        }
+        if (!maker.IsDone()) {
+            return failure("build", "BUILD_FAILED",
+                           "OCCT did not complete the edge treatment");
+        }
+
+        TopoDS_Shape makerResult;
+        try {
+            makerResult = maker.Shape();
+        } catch (const Standard_Failure& error) {
+            return failure("result-validation", "RESULT_OCCT_EXCEPTION",
+                           error.GetMessageString());
+        } catch (const std::exception& error) {
+            return failure("result-validation", "RESULT_NATIVE_EXCEPTION",
+                           error.what());
+        } catch (...) {
+            return failure("result-validation", "RESULT_NATIVE_EXCEPTION",
+                           "Unknown failure while retrieving the result");
+        }
+        if (makerResult.IsNull()) {
+            return failure("result-validation", "NULL_RESULT",
+                           "OCCT completed without an edge-treatment result");
+        }
