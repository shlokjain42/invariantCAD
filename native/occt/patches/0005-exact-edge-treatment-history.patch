+}
+
+bool InvariantCadEdgeTreatmentReport::hasResult() const {
+    return transfer_ && !transfer_->transferred && !transfer_->result.IsNull();
+}
+
+std::string InvariantCadEdgeTreatmentReport::transferCode(
+    const OcctKernel& kernel) const {
+    if (!transfer_) {
+        return "NO_RESULT";
+    }
+    if (transfer_->transferred || transfer_->result.IsNull()) {
+        return "ALREADY_TRANSFERRED";
+    }
+    if (transfer_->kernelInstanceToken != kernel.invariantcadInstanceToken_) {
+        return "WRONG_KERNEL";
+    }
+    return "READY";
+}
