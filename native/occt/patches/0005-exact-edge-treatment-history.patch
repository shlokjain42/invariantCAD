+    if (transfer_->topologyHistory.inputCounts.size() >
+        static_cast<size_t>(std::numeric_limits<int>::max())) {
+        throw std::overflow_error(
+            "InvariantCAD edge-treatment topology input count exceeds the ABI range");
+    }
+    return static_cast<int>(transfer_->topologyHistory.inputCounts.size());
