+        throw std::logic_error(
+            "InvariantCAD edge-treatment topology history is unavailable");
+    }
+    if (recordIndex < 0 ||
+        static_cast<size_t>(recordIndex) >= transfer_->topologyHistory.records.size()) {
+        throw std::out_of_range(
+            "InvariantCAD edge-treatment topology record index is out of range");
