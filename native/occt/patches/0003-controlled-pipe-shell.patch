--- a/facade/src/invariantcad_facade.cpp
+++ b/facade/src/invariantcad_facade.cpp
@@ -10,0 +11 @@
+#include <BRepBuilderAPI_TransitionMode.hxx>
@@ -11,0 +13 @@
+#include <BRepOffsetAPI_MakePipeShell.hxx>
@@ -43,0 +46,6 @@ struct InvariantCadDraftTransferState {
+struct InvariantCadPipeShellTransferState {
+    TopoDS_Shape result;
+    uint64_t kernelInstanceToken = 0;
+    bool transferred = false;
+};
+
@@ -411,0 +420,35 @@ std::string InvariantCadDraftReport::transferCode(const OcctKernel& kernel) cons
+uint32_t InvariantCadPipeShellReport::takeResultId(OcctKernel& kernel) {
+    const std::string state = transferCode(kernel);
+    if (state == "NO_RESULT") {
+        throw std::runtime_error("InvariantCAD PipeShell report has no transferable result");
+    }
+    if (state == "ALREADY_TRANSFERRED") {
+        throw std::runtime_error("InvariantCAD PipeShell result was already transferred");
+    }
+    if (state == "WRONG_KERNEL") {
+        throw std::runtime_error(
+            "InvariantCAD PipeShell result belongs to another kernel instance");
+    }
+    const uint32_t resultId = kernel.invariantcadStoreTransferredShape(transfer_->result);
+    transfer_->transferred = true;
+    transfer_->result.Nullify();
+    return resultId;
+}
+
+bool InvariantCadPipeShellReport::hasResult() const {
+    return transfer_ && !transfer_->transferred && !transfer_->result.IsNull();
+}
+
+std::string InvariantCadPipeShellReport::transferCode(const OcctKernel& kernel) const {
+    if (!transfer_) {
+        return "NO_RESULT";
+    }
+    if (transfer_->transferred || transfer_->result.IsNull()) {
+        return "ALREADY_TRANSFERRED";
+    }
+    if (transfer_->kernelInstanceToken != kernel.invariantcadInstanceToken_) {
+        return "WRONG_KERNEL";
+    }
+    return "READY";
+}
