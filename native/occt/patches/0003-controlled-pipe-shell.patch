+/// Transactional result of the controlled InvariantCAD PipeShell facade.
+/// A successful untaken report owns its result outside the kernel arena.
+struct InvariantCadPipeShellReport {
+    bool ok = false;
+    std::string stage = "validation";
+    std::string code = "INTERNAL_ERROR";
+    std::string message;
+    int occtStatus = -1;
+    double errorOnSurface = -1.0;
+    double tolerance3d = -1.0;
+    double boundaryTolerance = -1.0;
+    double angularTolerance = -1.0;
+    int buildCount = 0;
+    int solidificationCount = 0;
+
+    InvariantCadPipeShellReport() = default;
+    InvariantCadPipeShellReport(const InvariantCadPipeShellReport&) = default;
+    InvariantCadPipeShellReport& operator=(const InvariantCadPipeShellReport&) = default;
+    InvariantCadPipeShellReport(InvariantCadPipeShellReport&&) noexcept = default;
+    InvariantCadPipeShellReport& operator=(InvariantCadPipeShellReport&&) noexcept = default;
+
+    bool getOk() const { return ok; }
+    std::string getStage() const { return stage; }
+    std::string getCode() const { return code; }
+    std::string getMessage() const { return message; }
+    int getOcctStatus() const { return occtStatus; }
+    double getErrorOnSurface() const { return errorOnSurface; }
+    double getTolerance3d() const { return tolerance3d; }
+    double getBoundaryTolerance() const { return boundaryTolerance; }
+    double getAngularTolerance() const { return angularTolerance; }
+    int getBuildCount() const { return buildCount; }
+    int getSolidificationCount() const { return solidificationCount; }
+
+    uint32_t takeResultId(OcctKernel& kernel);
+    bool hasResult() const;
+    std::string transferCode(const OcctKernel& kernel) const;
+
+  private:
+    std::shared_ptr<InvariantCadPipeShellTransferState> transfer_;
+
+    friend InvariantCadPipeShellReport invariantcadPipeShellSolid(
+        OcctKernel& kernel, uint32_t profileWireId, uint32_t spineWireId,
+        double tolerance3d, double boundaryTolerance, double angularTolerance);
+};
+
