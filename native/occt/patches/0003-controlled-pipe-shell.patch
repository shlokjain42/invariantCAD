+
+InvariantCadPipeShellReport invariantcadPipeShellSolid(
+    OcctKernel& kernel, uint32_t profileWireId, uint32_t spineWireId,
+    double tolerance3d, double boundaryTolerance, double angularTolerance) {
+    int buildCount = 0;
+    int solidificationCount = 0;
+    auto failure = [&](const char* stage, const char* code, const char* message,
+                       int occtStatus = -1, double errorOnSurface = -1.0) {
+        InvariantCadPipeShellReport report;
+        report.stage = stage;
+        report.code = code;
+        report.message = message;
+        report.occtStatus = occtStatus;
+        report.errorOnSurface = errorOnSurface;
+        report.tolerance3d = tolerance3d;
+        report.boundaryTolerance = boundaryTolerance;
+        report.angularTolerance = angularTolerance;
+        report.buildCount = buildCount;
+        report.solidificationCount = solidificationCount;
+        return report;
+    };
+    const auto finitePositive = [](double value) {
+        return std::isfinite(value) && value > 0.0;
+    };
+    if (!finitePositive(tolerance3d) || !finitePositive(boundaryTolerance) ||
+        !finitePositive(angularTolerance)) {
+        return failure("validation", "INVALID_TOLERANCE",
+                       "PipeShell tolerances must be finite and positive");
+    }
+    if (tolerance3d > 1.0 || boundaryTolerance > 1.0 || angularTolerance > 0.1) {
+        return failure("validation", "TOLERANCE_OUT_OF_RANGE",
+                       "PipeShell tolerances exceed the facade ABI bounds");
+    }
+
+    const auto profileIt = kernel.arena_.find(profileWireId);
+    const auto spineIt = kernel.arena_.find(spineWireId);
+    if (profileIt == kernel.arena_.end()) {
+        return failure("input-validation", "INVALID_PROFILE_ID",
+                       "Profile ID is not present in the kernel arena");
+    }
+    if (spineIt == kernel.arena_.end()) {
+        return failure("input-validation", "INVALID_SPINE_ID",
+                       "Spine ID is not present in the kernel arena");
+    }
+    const TopoDS_Shape& profile = profileIt->second;
+    const TopoDS_Shape& spine = spineIt->second;
+    if (profile.IsNull() || profile.ShapeType() != TopAbs_WIRE) {
+        return failure("input-validation", "PROFILE_NOT_WIRE",
+                       "PipeShell profile must be a non-null top-level wire");
+    }
+    if (spine.IsNull() || spine.ShapeType() != TopAbs_WIRE) {
+        return failure("input-validation", "SPINE_NOT_WIRE",
+                       "PipeShell spine must be a non-null top-level wire");
+    }
+    try {
+        if (!BRepCheck_Analyzer(profile).IsValid() ||
+            !BRepCheck_Analyzer(spine).IsValid()) {
+            return failure("input-validation", "INVALID_INPUT_WIRE",
+                           "PipeShell profile and spine wires must be valid");
+        }
+    } catch (const Standard_Failure&) {
+        return failure("input-validation", "INPUT_VALIDATION_OCCT_EXCEPTION",
+                       "OCCT raised while validating PipeShell input wires");
+    } catch (const std::exception&) {
+        return failure("input-validation", "INPUT_VALIDATION_NATIVE_EXCEPTION",
+                       "Native code raised while validating PipeShell input wires");
+    } catch (...) {
+        return failure("input-validation", "INPUT_VALIDATION_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while validating PipeShell input wires");
+    }
+
+    std::unique_ptr<BRepOffsetAPI_MakePipeShell> maker;
+    try {
+        maker = std::make_unique<BRepOffsetAPI_MakePipeShell>(TopoDS::Wire(spine));
+        maker->SetMode(Standard_False);
+        maker->SetTransitionMode(BRepBuilderAPI_RightCorner);
+        maker->SetTolerance(tolerance3d, boundaryTolerance, angularTolerance);
+        maker->Add(profile, Standard_False, Standard_False);
+        if (!maker->IsReady()) {
+            return failure("prepare", "NOT_READY",
+                           "PipeShell is not ready after adding the profile");
+        }
+    } catch (const Standard_Failure&) {
+        return failure("prepare", "PREPARE_OCCT_EXCEPTION",
+                       "OCCT raised while preparing PipeShell");
+    } catch (const std::exception&) {
+        return failure("prepare", "PREPARE_NATIVE_EXCEPTION",
+                       "Native code raised while preparing PipeShell");
+    } catch (...) {
+        return failure("prepare", "PREPARE_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while preparing PipeShell");
+    }
+
+    try {
+        ++buildCount;
+        maker->Build();
+    } catch (const Standard_Failure&) {
+        return failure("build", "BUILD_OCCT_EXCEPTION",
+                       "OCCT raised while building PipeShell");
+    } catch (const std::exception&) {
+        return failure("build", "BUILD_NATIVE_EXCEPTION",
+                       "Native code raised while building PipeShell");
+    } catch (...) {
+        return failure("build", "BUILD_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while building PipeShell");
+    }
+
+    int occtStatus = -1;
+    bool buildDone = false;
+    try {
+        occtStatus = static_cast<int>(maker->GetStatus());
+        buildDone = maker->IsDone();
+    } catch (...) {
+        // Stable build diagnostics survive optional status extraction.
+    }
+    if (!buildDone) {
+        return failure("build", "BUILD_FAILED", "OCCT did not complete PipeShell",
+                       occtStatus);
+    }
+
+    double errorOnSurface = -1.0;
+    try {
+        errorOnSurface = maker->ErrorOnSurface();
+    } catch (const Standard_Failure&) {
+        return failure("quality", "SURFACE_ERROR_OCCT_EXCEPTION",
+                       "OCCT raised while reading PipeShell surface error", occtStatus);
+    } catch (const std::exception&) {
+        return failure("quality", "SURFACE_ERROR_NATIVE_EXCEPTION",
+                       "Native code raised while reading PipeShell surface error", occtStatus);
+    } catch (...) {
+        return failure("quality", "SURFACE_ERROR_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while reading PipeShell surface error",
+                       occtStatus);
+    }
+    if (!std::isfinite(errorOnSurface) || errorOnSurface < 0.0) {
+        return failure("quality", "INVALID_SURFACE_ERROR",
+                       "PipeShell returned an invalid surface error", occtStatus,
+                       errorOnSurface);
+    }
+
+    bool solidDone = false;
+    try {
+        ++solidificationCount;
+        solidDone = maker->MakeSolid();
+    } catch (const Standard_Failure&) {
+        return failure("solid", "SOLID_OCCT_EXCEPTION",
+                       "OCCT raised while closing PipeShell as a solid", occtStatus,
+                       errorOnSurface);
+    } catch (const std::exception&) {
+        return failure("solid", "SOLID_NATIVE_EXCEPTION",
+                       "Native code raised while closing PipeShell as a solid", occtStatus,
+                       errorOnSurface);
+    } catch (...) {
+        return failure("solid", "SOLID_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while closing PipeShell as a solid", occtStatus,
+                       errorOnSurface);
+    }
+    if (!solidDone) {
+        return failure("solid", "SOLID_FAILED",
+                       "PipeShell could not close the profile into a solid", occtStatus,
+                       errorOnSurface);
+    }
+
+    TopoDS_Shape result;
+    try {
+        result = maker->Shape();
+        if (result.IsNull()) {
+            return failure("result-validation", "NULL_RESULT",
+                           "PipeShell completed without a result", occtStatus,
+                           errorOnSurface);
+        }
+        if (result.ShapeType() != TopAbs_SOLID) {
+            return failure("result-validation", "RESULT_NOT_SOLID",
+                           "PipeShell result is not a top-level solid", occtStatus,
+                           errorOnSurface);
+        }
+        if (!BRepCheck_Analyzer(result).IsValid()) {
+            return failure("result-validation", "INVALID_RESULT",
+                           "PipeShell produced an invalid solid", occtStatus,
+                           errorOnSurface);
+        }
+    } catch (const Standard_Failure&) {
+        return failure("result-validation", "RESULT_VALIDATION_OCCT_EXCEPTION",
+                       "OCCT raised while validating the PipeShell result", occtStatus,
+                       errorOnSurface);
+    } catch (const std::exception&) {
+        return failure("result-validation", "RESULT_VALIDATION_NATIVE_EXCEPTION",
+                       "Native code raised while validating the PipeShell result", occtStatus,
+                       errorOnSurface);
+    } catch (...) {
+        return failure("result-validation", "RESULT_VALIDATION_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while validating the PipeShell result", occtStatus,
+                       errorOnSurface);
+    }
+
+    try {
+        auto transfer = std::make_shared<InvariantCadPipeShellTransferState>();
+        transfer->result = result;
+        transfer->kernelInstanceToken = kernel.invariantcadInstanceToken_;
+
+        InvariantCadPipeShellReport report;
+        report.ok = true;
+        report.stage = "complete";
+        report.code = "OK";
+        report.message = "Controlled PipeShell completed";
+        report.occtStatus = occtStatus;
+        report.errorOnSurface = errorOnSurface;
+        report.tolerance3d = tolerance3d;
+        report.boundaryTolerance = boundaryTolerance;
+        report.angularTolerance = angularTolerance;
+        report.buildCount = buildCount;
+        report.solidificationCount = solidificationCount;
+        report.transfer_ = std::move(transfer);
+        return report;
+    } catch (const std::exception&) {
+        return failure("result-ownership", "RESULT_OWNERSHIP_NATIVE_EXCEPTION",
+                       "Native code could not own the PipeShell result", occtStatus,
+                       errorOnSurface);
+    } catch (...) {
+        return failure("result-ownership", "RESULT_OWNERSHIP_UNKNOWN_EXCEPTION",
+                       "Unknown native failure while owning the PipeShell result", occtStatus,
+                       errorOnSurface);
+    }
