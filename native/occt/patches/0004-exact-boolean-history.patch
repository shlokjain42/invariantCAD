+struct IndexedOperandTopology {
+    IndexedShapeMap faces;
+    IndexedShapeMap edges;
+    IndexedShapeMap vertices;
+};
+
+struct BooleanOperandCopy {
+    std::unique_ptr<BRepBuilderAPI_Copy> copier;
+    TopoDS_Shape shape;
+};
+
+struct ClaimedResultTopology {
+    std::vector<bool> faces;
+    std::vector<bool> edges;
+    std::vector<bool> vertices;
+};
+
+IndexedOperandTopology indexBooleanOperand(const TopoDS_Shape& shape,
+                                            int sourceShapeIndex,
+                                            const char* problemDomain) {
+    IndexedOperandTopology topology;
+    indexTopology(shape, TopAbs_FACE, InvariantCadTopologyKindFace, problemDomain,
+                  sourceShapeIndex, topology.faces);
+    indexTopology(shape, TopAbs_EDGE, InvariantCadTopologyKindEdge, problemDomain,
+                  sourceShapeIndex, topology.edges);
+    indexTopology(shape, TopAbs_VERTEX, InvariantCadTopologyKindVertex, problemDomain,
+                  sourceShapeIndex, topology.vertices);
+    return topology;
+}
+
+const IndexedShapeMap& mapForKind(const IndexedOperandTopology& topology, int kind) {
+    switch (kind) {
+    case InvariantCadTopologyKindFace: return topology.faces;
+    case InvariantCadTopologyKindEdge: return topology.edges;
+    case InvariantCadTopologyKindVertex: return topology.vertices;
+    default:
+        throw HistoryContractError("HISTORY_KIND_UNSUPPORTED",
+                                   "Indexed topology kind is unsupported", kind);
+    }
+}
+
+int kindForShape(const TopoDS_Shape& shape);
+
+TopoDS_Shape copiedBooleanSource(
+    const BooleanOperandCopy& operandCopy, const TopoDS_Shape& originalSource,
+    int sourceShapeIndex, int sourceKind, int sourceIndex) {
+    if (operandCopy.copier == nullptr) {
+        throw HistoryContractError(
+            "HISTORY_COPY_UNAVAILABLE",
+            "Boolean operand copy mapping is unavailable", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    }
+
+    TopoDS_Shape copiedSource;
+    try {
+        copiedSource = operandCopy.copier->ModifiedShape(originalSource);
+    } catch (const Standard_Failure&) {
+        throw HistoryContractError(
+            "HISTORY_COPY_SUCCESSOR_OCCT_EXCEPTION",
+            "OCCT raised while resolving a copied Boolean source", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    } catch (const std::exception&) {
+        throw HistoryContractError(
+            "HISTORY_COPY_SUCCESSOR_NATIVE_EXCEPTION",
+            "Native code raised while resolving a copied Boolean source",
+            sourceKind, sourceIndex, "source", sourceShapeIndex);
+    } catch (...) {
+        throw HistoryContractError(
+            "HISTORY_COPY_SUCCESSOR_NATIVE_EXCEPTION",
+            "Unknown native failure while resolving a copied Boolean source",
+            sourceKind, sourceIndex, "source", sourceShapeIndex);
+    }
+
+    if (copiedSource.IsNull()) {
+        throw HistoryContractError(
+            "HISTORY_COPY_NULL_SUCCESSOR",
+            "Boolean operand copy returned a null topology successor",
+            sourceKind, sourceIndex, "source", sourceShapeIndex);
+    }
+    if (copiedSource.IsSame(originalSource)) {
+        throw HistoryContractError(
+            "HISTORY_COPY_NOT_ISOLATED",
+            "Boolean operand copy shares topology with its source", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    }
+    if (kindForShape(copiedSource) != sourceKind) {
+        throw HistoryContractError(
+            "HISTORY_COPY_KIND_CHANGED",
+            "Boolean operand copy changed topology kind", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    }
+    return copiedSource;
+}
+
+int kindForShape(const TopoDS_Shape& shape) {
+    switch (shape.ShapeType()) {
+    case TopAbs_FACE: return InvariantCadTopologyKindFace;
+    case TopAbs_EDGE: return InvariantCadTopologyKindEdge;
+    case TopAbs_VERTEX: return InvariantCadTopologyKindVertex;
+    default: return InvariantCadTopologyKindNone;
+    }
+}
+
+using BooleanEvolutionRecordKey = std::tuple<int, int, int, int, int, int>;
+
+BooleanEvolutionRecordKey booleanEvolutionRecordKey(
+    const InvariantCadTopologyEvolutionRecord& record) {
+    return std::make_tuple(record.sourceShapeIndex, record.sourceKind,
+                           record.sourceIndex, record.relation,
+                           record.resultKind, record.resultIndex);
+}
+
+void appendBooleanRecord(
+    const InvariantCadTopologyEvolutionRecord& record, int maxHistoryRecords,
+    std::set<BooleanEvolutionRecordKey>& uniqueRecords,
+    std::vector<InvariantCadTopologyEvolutionRecord>& records) {
+    const BooleanEvolutionRecordKey key = booleanEvolutionRecordKey(record);
+    if (uniqueRecords.find(key) != uniqueRecords.end()) {
+        return;
+    }
+    if (records.size() >= static_cast<size_t>(maxHistoryRecords)) {
+        throw HistoryContractError(
+            "HISTORY_RECORD_LIMIT_EXCEEDED",
+            "Boolean indexed topology history exceeds the configured record limit");
+    }
+    uniqueRecords.insert(key);
+    records.push_back(record);
+}
+
+void claimBooleanResult(const IndexedOperandTopology& result, int resultKind,
+                        const TopoDS_Shape& successor, int sourceShapeIndex,
+                        int sourceKind, int sourceIndex, int relation,
+                        ClaimedResultTopology& claimed,
+                        int maxHistoryRecords,
+                        std::set<BooleanEvolutionRecordKey>& uniqueRecords,
+                        std::vector<InvariantCadTopologyEvolutionRecord>& records) {
+    const IndexedShapeMap& resultMap = mapForKind(result, resultKind);
+    const int oneBasedResultIndex = resultMap.FindIndex(successor);
+    if (oneBasedResultIndex <= 0) {
+        throw HistoryContractError(
+            "HISTORY_SUCCESSOR_NOT_IN_RESULT",
+            "Boolean history successor is absent from the final result", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    }
+    const int resultIndex = oneBasedResultIndex - 1;
+    std::vector<bool>* claimedKind = nullptr;
+    switch (resultKind) {
+    case InvariantCadTopologyKindFace: claimedKind = &claimed.faces; break;
+    case InvariantCadTopologyKindEdge: claimedKind = &claimed.edges; break;
+    case InvariantCadTopologyKindVertex: claimedKind = &claimed.vertices; break;
+    default: break;
+    }
+    if (claimedKind == nullptr || static_cast<size_t>(resultIndex) >= claimedKind->size()) {
+        throw HistoryContractError(
+            "HISTORY_RESULT_INDEX_INVALID",
+            "Boolean history resolved an invalid result topology index", resultKind,
+            resultIndex, "result", -1);
+    }
+    (*claimedKind)[static_cast<size_t>(resultIndex)] = true;
+    appendBooleanRecord(
+        {sourceShapeIndex, sourceKind, sourceIndex, relation, resultKind,
+         resultIndex},
+        maxHistoryRecords, uniqueRecords, records);
+}
+
+void appendBooleanSourceRecords(
+    const BRepTools_History& nativeHistory, const IndexedOperandTopology& result,
+    int sourceShapeIndex, int sourceKind, int sourceIndex,
+    const TopoDS_Shape& source, ClaimedResultTopology& claimed,
+    int maxHistoryRecords,
+    std::set<BooleanEvolutionRecordKey>& uniqueRecords,
+    std::vector<InvariantCadTopologyEvolutionRecord>& records) {
+    const IndexedShapeMap& sameKindResult = mapForKind(result, sourceKind);
+    const int oneBasedDirectResultIndex = sameKindResult.FindIndex(source);
+    const NCollection_List<TopoDS_Shape>& modified = nativeHistory.Modified(source);
+    const NCollection_List<TopoDS_Shape>& generated = nativeHistory.Generated(source);
+    const bool removed = nativeHistory.IsRemoved(source);
+    // Merged multi-stage OCCT history may retain IsRemoved from an intermediate
+    // step even when the final result still contains a direct or Modified
+    // identity successor. Final-result membership is the stronger fact.
+    const bool hasIdentitySuccessor =
+        oneBasedDirectResultIndex > 0 || !modified.IsEmpty();
+
+    if (oneBasedDirectResultIndex > 0) {
+        const TopoDS_Shape& canonicalResult =
+            sameKindResult.FindKey(oneBasedDirectResultIndex);
+        bool directReportedModified = false;
+        for (NCollection_List<TopoDS_Shape>::Iterator iterator(modified);
+             iterator.More(); iterator.Next()) {
+            if (sameKindResult.FindIndex(iterator.Value()) ==
+                oneBasedDirectResultIndex) {
+                directReportedModified = true;
+                break;
+            }
+        }
+        claimBooleanResult(
+            result, sourceKind, canonicalResult, sourceShapeIndex, sourceKind,
+            sourceIndex,
+            source.IsEqual(canonicalResult) && !directReportedModified
+                ? InvariantCadTopologyRelationPreserved
+                : InvariantCadTopologyRelationModified,
+            claimed, maxHistoryRecords, uniqueRecords, records);
+    }
+
+    for (NCollection_List<TopoDS_Shape>::Iterator iterator(modified);
+         iterator.More(); iterator.Next()) {
+        const TopoDS_Shape& successor = iterator.Value();
+        const int resultKind = kindForShape(successor);
+        if (resultKind == InvariantCadTopologyKindNone || resultKind != sourceKind) {
+            throw HistoryContractError(
+                "HISTORY_MODIFIED_KIND_CHANGED",
+                "Boolean modified successor changed topology kind", sourceKind,
+                sourceIndex, "source", sourceShapeIndex);
+        }
+        claimBooleanResult(result, resultKind, successor, sourceShapeIndex,
+                           sourceKind, sourceIndex,
+                           InvariantCadTopologyRelationModified, claimed,
+                           maxHistoryRecords, uniqueRecords, records);
+    }
+
+    for (NCollection_List<TopoDS_Shape>::Iterator iterator(generated);
+         iterator.More(); iterator.Next()) {
+        const TopoDS_Shape& successor = iterator.Value();
+        const int resultKind = kindForShape(successor);
+        if (resultKind == InvariantCadTopologyKindNone) {
+            throw HistoryContractError(
+                "HISTORY_GENERATED_KIND_UNSUPPORTED",
+                "Boolean generated successor has an unsupported topology kind",
+                sourceKind, sourceIndex, "source", sourceShapeIndex);
+        }
+        claimBooleanResult(result, resultKind, successor, sourceShapeIndex,
+                           sourceKind, sourceIndex,
+                           InvariantCadTopologyRelationGenerated, claimed,
+                           maxHistoryRecords, uniqueRecords, records);
+    }
+
+    if (removed && !hasIdentitySuccessor) {
+        appendBooleanRecord(
+            {sourceShapeIndex, sourceKind, sourceIndex,
+             InvariantCadTopologyRelationDeleted,
+             InvariantCadTopologyKindNone, -1},
+            maxHistoryRecords, uniqueRecords, records);
+    } else if (!hasIdentitySuccessor) {
+        throw HistoryContractError(
+            "HISTORY_SOURCE_UNCLAIMED",
+            "Boolean source has no identity successor or deleted record", sourceKind,
+            sourceIndex, "source", sourceShapeIndex);
+    }
+}
+
+void appendUnclaimedBooleanCreatedRecords(
+    int resultKind, std::vector<bool>& claimed, int maxHistoryRecords,
+    std::set<BooleanEvolutionRecordKey>& uniqueRecords,
+    std::vector<InvariantCadTopologyEvolutionRecord>& records) {
+    for (size_t resultIndex = 0; resultIndex < claimed.size(); ++resultIndex) {
+        if (claimed[resultIndex]) {
+            continue;
+        }
+        appendBooleanRecord(
+            {-1, InvariantCadTopologyKindNone, -1,
+             InvariantCadTopologyRelationCreated, resultKind,
+             static_cast<int>(resultIndex)},
+            maxHistoryRecords, uniqueRecords, records);
+        claimed[resultIndex] = true;
+    }
+}
+
+bool topologyEvolutionRecordLess(const InvariantCadTopologyEvolutionRecord& first,
+                                 const InvariantCadTopologyEvolutionRecord& second) {
+    return std::tie(first.sourceShapeIndex, first.sourceKind, first.sourceIndex,
+                    first.relation, first.resultKind, first.resultIndex) <
+           std::tie(second.sourceShapeIndex, second.sourceKind, second.sourceIndex,
+                    second.relation, second.resultKind, second.resultIndex);
+}
+
+InvariantCadIndexedTopologyEvolution buildBooleanTopologyHistory(
+    const BRepTools_History& nativeHistory,
+    const std::vector<TopoDS_Shape>& inputShapes,
+    const std::vector<BooleanOperandCopy>& operandCopies,
+    const TopoDS_Shape& resultShape, int maxHistoryRecords) {
+    if (inputShapes.size() != operandCopies.size()) {
+        throw HistoryContractError(
+            "HISTORY_COPY_COUNT_MISMATCH",
+            "Boolean operand copy count does not match the source count");
+    }
+    std::vector<IndexedOperandTopology> inputs;
+    inputs.reserve(inputShapes.size());
+    std::vector<IndexedOperandTopology> copiedInputs;
+    copiedInputs.reserve(operandCopies.size());
+    InvariantCadIndexedTopologyEvolution history;
+    history.version = kTopologyHistoryVersion;
+    for (size_t sourceShapeIndex = 0; sourceShapeIndex < inputShapes.size();
+         ++sourceShapeIndex) {
+        if (sourceShapeIndex > static_cast<size_t>(std::numeric_limits<int>::max())) {
+            throw HistoryContractError(
+                "HISTORY_INPUT_COUNT_OVERFLOW",
+                "Boolean input shape count exceeds the ABI range");
+        }
+        inputs.push_back(indexBooleanOperand(
+            inputShapes[sourceShapeIndex], static_cast<int>(sourceShapeIndex),
+            "source"));
+        copiedInputs.push_back(indexBooleanOperand(
+            operandCopies[sourceShapeIndex].shape,
+            static_cast<int>(sourceShapeIndex), "source"));
+        const IndexedOperandTopology& input = inputs.back();
+        history.inputCounts.push_back(
+            {input.faces.Extent(), input.edges.Extent(), input.vertices.Extent()});
+    }
+    const IndexedOperandTopology result =
+        indexBooleanOperand(resultShape, -1, "result");
+    history.resultCounts =
+        {result.faces.Extent(), result.edges.Extent(), result.vertices.Extent()};
+    ClaimedResultTopology claimed{
+        std::vector<bool>(static_cast<size_t>(result.faces.Extent()), false),
+        std::vector<bool>(static_cast<size_t>(result.edges.Extent()), false),
+        std::vector<bool>(static_cast<size_t>(result.vertices.Extent()), false),
+    };
+    std::set<BooleanEvolutionRecordKey> uniqueRecords;
+
+    for (size_t sourceShapeIndex = 0; sourceShapeIndex < inputs.size();
+         ++sourceShapeIndex) {
+        const int sourceShape = static_cast<int>(sourceShapeIndex);
+        for (const int sourceKind : {InvariantCadTopologyKindFace,
+                                     InvariantCadTopologyKindEdge,
+                                     InvariantCadTopologyKindVertex}) {
+            const IndexedShapeMap& sourceMap =
+                mapForKind(inputs[sourceShapeIndex], sourceKind);
+            const IndexedShapeMap& copiedSourceMap =
+                mapForKind(copiedInputs[sourceShapeIndex], sourceKind);
+            if (sourceMap.Extent() != copiedSourceMap.Extent()) {
+                throw HistoryContractError(
+                    "HISTORY_COPY_COUNT_CHANGED",
+                    std::string("Boolean operand copy changed the indexed ") +
+                        topologyKindName(sourceKind) + " count",
+                    sourceKind, -1, "source", sourceShape);
+            }
+            std::vector<bool> claimedCopiedSources(
+                static_cast<size_t>(copiedSourceMap.Extent()), false);
+            for (int oneBasedSourceIndex = 1;
+                 oneBasedSourceIndex <= sourceMap.Extent(); ++oneBasedSourceIndex) {
+                const int sourceIndex = oneBasedSourceIndex - 1;
+                const TopoDS_Shape copiedSource = copiedBooleanSource(
+                    operandCopies[sourceShapeIndex],
+                    sourceMap.FindKey(oneBasedSourceIndex), sourceShape,
+                    sourceKind, sourceIndex);
+                const int oneBasedCopiedSourceIndex =
+                    copiedSourceMap.FindIndex(copiedSource);
+                if (oneBasedCopiedSourceIndex <= 0) {
+                    throw HistoryContractError(
+                        "HISTORY_COPY_SUCCESSOR_NOT_IN_COPY",
+                        "Copied Boolean source is absent from the copied operand",
+                        sourceKind, sourceIndex, "source", sourceShape);
+                }
+                const size_t copiedSourceIndex =
+                    static_cast<size_t>(oneBasedCopiedSourceIndex - 1);
+                if (claimedCopiedSources[copiedSourceIndex]) {
+                    throw HistoryContractError(
+                        "HISTORY_COPY_SUCCESSOR_NOT_UNIQUE",
+                        "Multiple Boolean sources resolve to one copied topology item",
+                        sourceKind, sourceIndex, "source", sourceShape);
+                }
+                claimedCopiedSources[copiedSourceIndex] = true;
+                appendBooleanSourceRecords(
+                    nativeHistory, result, sourceShape, sourceKind,
+                    sourceIndex, copiedSource,
+                    claimed, maxHistoryRecords, uniqueRecords, history.records);
+            }
+        }
+    }
+
+    // OCCT can produce higher-order topology from the interaction of multiple
+    // tools without attributing it to any one operand. Preserve every available
+    // native P/M/G claim first, then mark only the residual result items as
+    // source-less CREATED by the Boolean operation.
+    appendUnclaimedBooleanCreatedRecords(
+        InvariantCadTopologyKindFace, claimed.faces, maxHistoryRecords,
+        uniqueRecords, history.records);
+    appendUnclaimedBooleanCreatedRecords(
+        InvariantCadTopologyKindEdge, claimed.edges, maxHistoryRecords,
+        uniqueRecords, history.records);
+    appendUnclaimedBooleanCreatedRecords(
+        InvariantCadTopologyKindVertex, claimed.vertices, maxHistoryRecords,
+        uniqueRecords, history.records);
+
+    std::sort(history.records.begin(), history.records.end(),
+              topologyEvolutionRecordLess);
+    std::map<std::tuple<int, int, int, int, int>, int> linkedRelations;
+    for (const InvariantCadTopologyEvolutionRecord& record : history.records) {
+        if (record.relation == InvariantCadTopologyRelationDeleted) {
+            continue;
+        }
+        const auto key = std::make_tuple(
+            record.sourceShapeIndex, record.sourceKind, record.sourceIndex,
+            record.resultKind, record.resultIndex);
+        const auto insertion = linkedRelations.emplace(key, record.relation);
+        if (!insertion.second && insertion.first->second != record.relation) {
+            throw HistoryContractError(
+                "HISTORY_LINK_CONTRADICTION",
+                "Boolean source/result link has conflicting relations",
+                record.sourceKind, record.sourceIndex, "source",
+                record.sourceShapeIndex);
+        }
+    }
+    if (history.records.size() >
+        static_cast<size_t>(std::numeric_limits<int>::max())) {
+        throw HistoryContractError(
+            "HISTORY_RECORD_COUNT_OVERFLOW",
+            "Boolean indexed topology history exceeds the ABI record range");
+    }
+    history.complete = true;
+    return history;
+}
