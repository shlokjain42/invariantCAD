+uint32_t InvariantCadBooleanReport::takeResultId(OcctKernel& kernel) {
+    const std::string state = transferCode(kernel);
+    if (state == "NO_RESULT") {
+        throw std::runtime_error("InvariantCAD Boolean report has no transferable result");
+    }
+    if (state == "ALREADY_TRANSFERRED") {
+        throw std::runtime_error("InvariantCAD Boolean result was already transferred");
+    }
+    if (state == "WRONG_KERNEL") {
+        throw std::runtime_error(
+            "InvariantCAD Boolean result belongs to another kernel instance");
+    }
+    const uint32_t resultId = kernel.invariantcadStoreTransferredShape(transfer_->result);
+    transfer_->transferred = true;
+    transfer_->result.Nullify();
+    return resultId;
+}
+
+bool InvariantCadBooleanReport::hasResult() const {
+    return transfer_ && !transfer_->transferred && !transfer_->result.IsNull();
+}
+
+std::string InvariantCadBooleanReport::transferCode(const OcctKernel& kernel) const {
+    if (!transfer_) {
+        return "NO_RESULT";
+    }
+    if (transfer_->transferred || transfer_->result.IsNull()) {
+        return "ALREADY_TRANSFERRED";
+    }
+    if (transfer_->kernelInstanceToken != kernel.invariantcadInstanceToken_) {
+        return "WRONG_KERNEL";
+    }
+    return "READY";
+}
