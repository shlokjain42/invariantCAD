+InvariantCadBooleanReport invariantcadBooleanAtomic(
+    OcctKernel& kernel, int operation, uint32_t targetId,
+    std::vector<uint32_t> toolIds, int maxHistoryRecords) {
+    int buildCount = 0;
+    int failedToolIndex = -1;
+    auto failure = [&](const char* stage, const char* code, const std::string& message) {
+        InvariantCadBooleanReport report;
+        report.stage = stage;
+        report.code = code;
+        report.message = message;
+        report.operation = operation;
+        report.requestedToolCount = static_cast<int>(toolIds.size());
+        report.buildCount = buildCount;
+        report.failedToolIndex = failedToolIndex;
+        return report;
+    };
+    if (operation != InvariantCadBooleanOperationUnion &&
+        operation != InvariantCadBooleanOperationSubtract &&
+        operation != InvariantCadBooleanOperationIntersect) {
+        return failure("validation", "INVALID_OPERATION",
+                       "Boolean operation code is not supported");
+    }
+    if (maxHistoryRecords < 0) {
+        return failure("validation", "INVALID_HISTORY_RECORD_LIMIT",
+                       "Boolean history record limit must be non-negative");
+    }
+    if (toolIds.empty()) {
+        return failure("validation", "EMPTY_TOOL_LIST",
+                       "Boolean operations require at least one tool");
+    }
+    if (toolIds.size() >= static_cast<size_t>(std::numeric_limits<int>::max())) {
+        return failure("validation", "TOOL_COUNT_OVERFLOW",
+                       "Boolean tool count exceeds the ABI range");
+    }
+
+    std::vector<TopoDS_Shape> inputShapes;
+    inputShapes.reserve(toolIds.size() + 1);
+    try {
+        const auto target = kernel.arena_.find(targetId);
+        if (target == kernel.arena_.end()) {
+            return failure("validation", "SHAPE_ID_NOT_FOUND",
+                           "Boolean target shape ID is absent from this kernel");
+        }
+        inputShapes.push_back(target->second);
+        if (inputShapes.front().IsNull()) {
+            return failure("validation", "NULL_TARGET",
+                           "Boolean target is a null shape");
+        }
+        for (size_t toolIndex = 0; toolIndex < toolIds.size(); ++toolIndex) {
+            failedToolIndex = static_cast<int>(toolIndex);
+            const auto tool = kernel.arena_.find(toolIds[toolIndex]);
+            if (tool == kernel.arena_.end()) {
+                return failure("validation", "SHAPE_ID_NOT_FOUND",
+                               "Boolean tool shape ID is absent from this kernel");
+            }
+            inputShapes.push_back(tool->second);
+            if (inputShapes.back().IsNull()) {
+                return failure("validation", "NULL_TOOL",
+                               "Boolean tool is a null shape");
+            }
+        }
+        failedToolIndex = -1;
+    } catch (const std::exception& error) {
+        return failure("validation", "SHAPE_LOOKUP_FAILED", error.what());
+    } catch (...) {
+        return failure("validation", "SHAPE_LOOKUP_FAILED",
+                       "Unknown failure while resolving Boolean shapes");
+    }
+
+    // OCCT's internal TopoDS_Builder::Add freezes input TShapes even when the
+    // Boolean builder is in non-destructive mode. Run the algorithm on
+    // topology-independent copies so the arena operands remain byte-for-byte
+    // stable. Geometry and triangulations are shared: non-destructive Boolean
+    // construction does not mutate them, while the copied TShapes isolate the
+    // status flags that TopoDS_Builder::Add changes.
+    std::vector<BooleanOperandCopy> operandCopies;
+    operandCopies.reserve(inputShapes.size());
+    try {
+        for (size_t sourceShapeIndex = 0; sourceShapeIndex < inputShapes.size();
+             ++sourceShapeIndex) {
+            failedToolIndex = sourceShapeIndex == 0
+                                  ? -1
+                                  : static_cast<int>(sourceShapeIndex - 1);
+            auto copier = std::make_unique<BRepBuilderAPI_Copy>(
+                inputShapes[sourceShapeIndex], false, false);
+            if (!copier->IsDone()) {
+                return failure("build", "BOOLEAN_OPERAND_COPY_FAILED",
+                               "OCCT did not complete a Boolean operand copy");
+            }
+            const TopoDS_Shape copiedShape = copier->Shape();
+            if (copiedShape.IsNull() || copiedShape.IsSame(inputShapes[sourceShapeIndex])) {
+                return failure(
+                    "build", "BOOLEAN_OPERAND_COPY_NOT_ISOLATED",
+                    "OCCT did not produce an isolated Boolean operand copy");
+            }
+            operandCopies.push_back({std::move(copier), copiedShape});
+        }
+        failedToolIndex = -1;
+    } catch (const Standard_Failure& error) {
+        return failure("build", "BOOLEAN_OPERAND_COPY_OCCT_EXCEPTION",
+                       error.what());
+    } catch (const std::exception& error) {
+        return failure("build", "BOOLEAN_OPERAND_COPY_NATIVE_EXCEPTION",
+                       error.what());
+    } catch (...) {
+        return failure("build", "BOOLEAN_OPERAND_COPY_NATIVE_EXCEPTION",
+                       "Unknown native failure while copying Boolean operands");
+    }
+
+    TopoDS_Shape result;
+    Handle(BRepTools_History) nativeHistory = new BRepTools_History();
+    try {
+        if (operation == InvariantCadBooleanOperationSubtract) {
+            NCollection_List<TopoDS_Shape> arguments;
+            arguments.Append(operandCopies.front().shape);
+            NCollection_List<TopoDS_Shape> tools;
+            for (size_t toolIndex = 1; toolIndex < operandCopies.size(); ++toolIndex) {
+                tools.Append(operandCopies[toolIndex].shape);
+            }
+            BRepAlgoAPI_Cut cutter;
+            cutter.SetArguments(arguments);
+            cutter.SetTools(tools);
+            cutter.SetNonDestructive(true);
+            cutter.SetRunParallel(true);
+            cutter.SetUseOBB(true);
+            ++buildCount;
+            cutter.Build();
+            if (!cutter.IsDone() || cutter.HasErrors()) {
+                return failure("build", "BOOLEAN_BUILD_FAILED",
+                               "OCCT multi-tool cut did not complete");
+            }
+            result = cutter.Shape();
+            nativeHistory->Merge(cutter.History());
+        } else {
+            TopoDS_Shape current = operandCopies.front().shape;
+            for (size_t toolIndex = 0; toolIndex < toolIds.size(); ++toolIndex) {
+                failedToolIndex = static_cast<int>(toolIndex);
+                NCollection_List<TopoDS_Shape> arguments;
+                arguments.Append(current);
+                NCollection_List<TopoDS_Shape> tools;
+                tools.Append(operandCopies[toolIndex + 1].shape);
+                if (operation == InvariantCadBooleanOperationUnion) {
+                    BRepAlgoAPI_Fuse maker;
+                    maker.SetArguments(arguments);
+                    maker.SetTools(tools);
+                    maker.SetNonDestructive(true);
+                    ++buildCount;
+                    maker.Build();
+                    if (!maker.IsDone() || maker.HasErrors()) {
+                        return failure("build", "BOOLEAN_BUILD_FAILED",
+                                       "OCCT ordered fuse step did not complete");
+                    }
+                    current = maker.Shape();
+                    nativeHistory->Merge(maker.History());
+                } else {
+                    BRepAlgoAPI_Common maker;
+                    maker.SetArguments(arguments);
+                    maker.SetTools(tools);
+                    maker.SetNonDestructive(true);
+                    ++buildCount;
+                    maker.Build();
+                    if (!maker.IsDone() || maker.HasErrors()) {
+                        return failure("build", "BOOLEAN_BUILD_FAILED",
+                                       "OCCT ordered common step did not complete");
+                    }
+                    current = maker.Shape();
+                    nativeHistory->Merge(maker.History());
+                }
+            }
+            failedToolIndex = -1;
+            result = current;
+        }
+    } catch (const Standard_Failure& error) {
+        return failure("build", "BOOLEAN_OCCT_EXCEPTION", error.GetMessageString());
+    } catch (const std::exception& error) {
+        return failure("build", "BOOLEAN_NATIVE_EXCEPTION", error.what());
+    } catch (...) {
+        return failure("build", "BOOLEAN_NATIVE_EXCEPTION",
+                       "Unknown native failure while building Boolean result");
+    }
+    if (result.IsNull()) {
+        return failure("build", "NULL_RESULT", "OCCT Boolean produced a null result");
+    }
+
+    InvariantCadIndexedTopologyEvolution topologyHistory;
+    try {
+        topologyHistory =
+            buildBooleanTopologyHistory(*nativeHistory, inputShapes,
+                                        operandCopies, result, maxHistoryRecords);
+    } catch (const HistoryContractError& error) {
+        InvariantCadBooleanReport report = failure("history", error.code().c_str(),
+                                                   error.what());
+        report.historyProblemDomain = error.problemDomain();
+        report.historyProblemSourceShapeIndex = error.sourceShapeIndex();
+        report.historyProblemKind = error.problematicKind();
+        report.historyProblemIndex = error.problematicIndex();
+        return report;
+    } catch (const Standard_Failure& error) {
+        return failure("history", "HISTORY_OCCT_EXCEPTION",
+                       error.GetMessageString());
+    } catch (const std::exception& error) {
+        return failure("history", "HISTORY_NATIVE_EXCEPTION", error.what());
+    } catch (...) {
+        return failure("history", "HISTORY_NATIVE_EXCEPTION",
+                       "Unknown native failure while proving Boolean history");
+    }
+
+    InvariantCadBooleanReport report;
+    report.ok = true;
+    report.stage = "complete";
+    report.code = "OK";
+    report.message = "Boolean result and exact indexed history are ready";
+    report.operation = operation;
+    report.requestedToolCount = static_cast<int>(toolIds.size());
+    report.buildCount = buildCount;
+    report.failedToolIndex = -1;
+    report.transfer_ = std::make_shared<InvariantCadBooleanTransferState>();
+    report.transfer_->result = result;
+    report.transfer_->kernelInstanceToken = kernel.invariantcadInstanceToken_;
+    report.transfer_->topologyHistory = std::move(topologyHistory);
+    return report;
 }
 
