{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "InvariantCAD",
  "description": "Comprehensive, type-safe CAD-as-code for TypeScript.",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "logo": {
    "light": "/assets/logo-light.svg",
    "dark": "/assets/logo-dark.svg",
    "href": "/"
  },
  "favicon": "/assets/favicon.svg",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Manrope",
      "weight": 650
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "grid"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true,
    "codeblocks": "system"
  },
  "banner": {
    "content": "InvariantCAD 0.1 is an early public foundation. Check the [support matrix](/reference/support-matrix) before committing to a backend.",
    "dismissible": true,
    "type": "info"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/shlokjain42/invariantCAD"
      },
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/invariantcad"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/shlokjain42/invariantCAD"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/shlokjain42/invariantCAD"
    },
    "links": [
      {
        "header": "Learn",
        "items": [
          {
            "label": "Quickstart",
            "href": "/get-started/quickstart"
          },
          {
            "label": "Modeling",
            "href": "/modeling/parameters-and-expressions"
          },
          {
            "label": "Library reference",
            "href": "/reference/public-surface"
          }
        ]
      },
      {
        "header": "Project",
        "items": [
          {
            "label": "Roadmap",
            "href": "/roadmap"
          },
          {
            "label": "Security",
            "href": "/project/security"
          },
          {
            "label": "Changelog",
            "href": "https://github.com/shlokjain42/invariantCAD/blob/main/CHANGELOG.md"
          }
        ]
      }
    ]
  },
