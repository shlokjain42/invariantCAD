{
  "name": "invariantcad",
  "version": "0.1.0",
  "description": "Comprehensive, type-safe CAD-as-code for TypeScript",
  "author": {
    "name": "Shlok Jain",
    "url": "https://github.com/shlokjain42"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlokjain42/invariantCAD.git"
  },
  "homepage": "https://invariant-cad.mintlify.app",
  "bugs": {
    "url": "https://github.com/shlokjain42/invariantCAD/issues"
  },
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist",
    "docs",
    "licenses",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./conformance": {
      "types": "./dist/conformance.d.ts",
      "import": "./dist/conformance.js"
    },
    "./kernels/occt": {
      "types": "./dist/occt-kernel.d.ts",
      "import": "./dist/occt-kernel.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "invariantcad": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/stage-manifold-runtime.mjs",
    "check": "pnpm build && tsc --noEmit",
    "lint": "pnpm lint:source && pnpm format:check",
    "lint:source": "oxlint --deny-warnings --report-unused-disable-directives src tests examples scripts tsup.config.ts vitest.config.ts",
    "format:check": "node scripts/check-source-format.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "pnpm build && vite build --config tests/browser/vite.config.ts && playwright test --config tests/browser/playwright.config.ts",
    "artifact:fixture:occt": "tsx scripts/generate-occt-artifact-fixture.ts",
    "docs:generate": "node scripts/generate-docs-export-index.mjs",
    "docs:check": "node scripts/generate-docs-export-index.mjs --check && node scripts/check-docs.mjs",
    "docs:dev": "cd docs && pnpm dlx mint@4.2.728 dev",
    "docs:validate": "cd docs && pnpm dlx mint@4.2.728 validate",
    "docs:links": "cd docs && pnpm dlx mint@4.2.728 broken-links --check-anchors --check-redirects",
    "docs:release-check": "pnpm docs:validate && pnpm docs:links",
    "coverage": "vitest run --coverage",
    "audit:release": "node scripts/check-production-audit.mjs",
    "lint:package": "pnpm build && node scripts/check-package-bin.mjs && publint && attw --pack . --profile esm-only",
    "test:package": "pnpm pack --pack-destination .artifacts && node scripts/package-smoke.mjs",
    "example:bracket": "tsx examples/bracket.ts",
    "build:occt-facade": "./scripts/build-occt-facade.sh",
    "bundle:occt-facade": "node scripts/package-occt-facade-bundle.mjs",
    "verify:occt-facade-bundle": "node scripts/verify-occt-facade-bundle.mjs .artifacts/occt-facade-bundle/invariantcad-occt-facade-0.9.0 && node scripts/verify-occt-facade-bundle.mjs .artifacts/occt-facade-bundle/invariantcad-occt-facade-0.9.0.tar.gz",
    "test:occt-facade": "node scripts/test-occt-facade.mjs",
    "test:occt-draft-public": "tsx scripts/test-public-occt-draft.ts",
    "test:occt-persistence-public": "tsx scripts/test-public-occt-persistence.ts",
    "test:occt-artifact-owned": "tsx scripts/test-owned-occt-artifact.ts",
    "test:occt-facade-bundle": "pnpm bundle:occt-facade && pnpm verify:occt-facade-bundle && pnpm pack --pack-destination .artifacts && node scripts/package-smoke.mjs --owned-facade-runtime-dir .artifacts/occt-facade-bundle/invariantcad-occt-facade-0.9.0/runtime && pnpm test:occt-persistence-public -- --runtime-dir .artifacts/occt-facade-bundle/invariantcad-occt-facade-0.9.0/runtime && pnpm test:occt-artifact-owned -- --runtime-dir .artifacts/occt-facade-bundle/invariantcad-occt-facade-0.9.0/runtime",
    "prepack": "pnpm build",
    "verify": "pnpm check && pnpm lint && pnpm test && pnpm artifact:fixture:occt -- --version v2 --check && pnpm docs:check && pnpm lint:package && pnpm test:package",
    "release:check": "pnpm verify && pnpm audit:release && pnpm docs:release-check && pnpm test:browser"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "cad",
    "parametric",
    "brep",
    "solid-modeling",
    "typescript",
    "wasm"
  ],
  "dependencies": {
    "occt-wasm": "3.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "oxlint": "1.75.0",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.34.5",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  }
}
