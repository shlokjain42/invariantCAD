{
  "name": "invariantcad",
  "version": "0.1.0",
  "description": "Comprehensive, type-safe CAD-as-code for TypeScript",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "invariantcad": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint:package": "publint && attw --pack . --profile esm-only",
    "test:package": "node scripts/package-smoke.mjs",
    "example:bracket": "tsx examples/bracket.ts",
    "prepack": "pnpm build",
    "verify": "pnpm check && pnpm test && pnpm pack --pack-destination .artifacts && pnpm lint:package && pnpm test:package"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "cad",
    "parametric",
    "brep",
    "solid-modeling",
    "typescript",
    "wasm"
  ],
  "dependencies": {
    "manifold-3d": "^3.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
